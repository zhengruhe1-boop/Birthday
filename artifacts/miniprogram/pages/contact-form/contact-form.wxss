.form-page {
  min-height: 100vh;
  background: #f8fafc;
  display: flex;
  flex-direction: column;
}

.form-scroll { height: 100vh; }

.form-body { padding: 24rpx 32rpx; }

/* Avatar section */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 32rpx;
  padding: 32rpx 0 16rpx;
}

.form-avatar-wrap {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f43f5e, #fb923c);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
  margin-bottom: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(244,63,94,0.2);
}

.form-avatar-img { width: 160rpx; height: 160rpx; border-radius: 50%; }

.form-avatar-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.form-avatar-placeholder text {
  color: #fff;
  font-size: 56rpx;
  font-weight: 700;
}

.camera-icon { font-size: 48rpx; }

.avatar-edit-badge {
  position: absolute;
  bottom: 4rpx;
  right: 4rpx;
  width: 48rpx;
  height: 48rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.15);
}

.avatar-loading {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 24rpx;
}

.avatar-hint { font-size: 22rpx; color: #94a3b8; }

/* Form card */
.form-card {
  background: #fff;
  border-radius: 24rpx;
  border: 1rpx solid rgba(0,0,0,0.06);
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.field-group { margin-bottom: 28rpx; }
.field-group:last-child { margin-bottom: 0; }

.label {
  font-size: 26rpx;
  font-weight: 500;
  color: #1e293b;
  margin-bottom: 12rpx;
  display: block;
}
.label-required { color: #ef4444; margin-left: 4rpx; }
.label-optional { font-size: 22rpx; color: #94a3b8; font-weight: 400; margin-left: 8rpx; }

.input-field {
  width: 100%;
  height: 88rpx;
  border: 1rpx solid #e2e8f0;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #1e293b;
  background: #fafafa;
}

.field-hint {
  font-size: 22rpx;
  color: #94a3b8;
  display: block;
  margin-top: 10rpx;
  line-height: 1.6;
}

/* Gender row */
.gender-row {
  display: flex;
  gap: 16rpx;
}

.gender-btn {
  flex: 1;
  height: 72rpx;
  border: 1rpx solid #e2e8f0;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #94a3b8;
  background: #fafafa;
}
.gender-btn.active-male { background: #eff6ff; border-color: #3b82f6; color: #3b82f6; font-weight: 600; }
.gender-btn.active-female { background: #fdf2f8; border-color: #ec4899; color: #ec4899; font-weight: 600; }
.gender-btn.active-neutral { background: #f8fafc; border-color: #94a3b8; color: #64748b; font-weight: 600; }
.gender-btn:active { opacity: 0.75; }

/* Calendar toggle */
.cal-toggle {
  display: flex;
  background: #f1f5f9;
  border-radius: 16rpx;
  padding: 6rpx;
  gap: 6rpx;
}

.cal-tab {
  flex: 1;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  border-radius: 12rpx;
  color: #64748b;
}
.cal-tab.active {
  background: #fff;
  color: #f43f5e;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
}
.cal-tab:active { opacity: 0.75; }

/* Birthday row */
.birthday-row {
  display: flex;
  gap: 20rpx;
}
.birthday-col { flex: 1; }

/* Picker */
.picker-field {
  height: 88rpx;
  border: 1rpx solid #e2e8f0;
  border-radius: 16rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 28rpx;
  color: #1e293b;
  background: #fafafa;
}

.picker-arrow { color: #94a3b8; font-size: 32rpx; }

/* Zodiac */
.zodiac-tag {
  display: inline-flex;
  align-items: center;
  background: #fef3c7;
  color: #d97706;
  padding: 8rpx 20rpx;
  border-radius: 100rpx;
  font-size: 24rpx;
  margin-top: 16rpx;
}

/* Test email */
.test-email-btn {
  width: 100%;
  height: 72rpx;
  border: 1rpx solid #e2e8f0;
  border-radius: 16rpx;
  background: #fafafa;
  color: #1e293b;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 16rpx;
}
.test-email-btn.success { background: #f0fdf4; border-color: #86efac; color: #16a34a; }
.test-email-btn.error { background: #fef2f2; border-color: #fca5a5; color: #dc2626; }
.test-email-btn:active { opacity: 0.75; }

/* AI events */
.ai-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  cursor: pointer;
}
.ai-header:active { opacity: 0.75; }

.ai-header-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.ai-icon { font-size: 40rpx; }
.ai-title { font-size: 28rpx; font-weight: 600; display: block; }
.ai-desc { font-size: 22rpx; color: #94a3b8; display: block; }

.expand-arrow { font-size: 32rpx; color: #94a3b8; }

/* 点击生成按钮 */
.ai-generate-wrap {
  padding: 24rpx 0 8rpx;
  display: flex;
  justify-content: center;
}

.ai-generate-btn {
  background: linear-gradient(135deg, #f43f5e, #fb923c);
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  border-radius: 100rpx;
  padding: 0 48rpx;
  height: 72rpx;
  line-height: 72rpx;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(244,63,94,0.25);
}
.ai-generate-btn::after { border: none; }
.ai-generate-btn:active { opacity: 0.85; }

.ai-loading, .ai-error, .ai-empty {
  text-align: center;
  padding: 40rpx;
  color: #94a3b8;
  font-size: 26rpx;
  display: block;
}

.retry-btn {
  margin-top: 16rpx;
  color: #f43f5e;
  font-size: 26rpx;
  text-align: center;
}

.ai-events-list { margin-top: 24rpx; }

.ai-refresh-wrap {
  display: flex;
  justify-content: center;
  padding: 20rpx 0 8rpx;
}

.ai-refresh-btn {
  background: none;
  border: 1rpx solid #e2e8f0;
  color: #94a3b8;
  font-size: 22rpx;
  border-radius: 100rpx;
  padding: 0 32rpx;
  height: 56rpx;
  line-height: 56rpx;
}
.ai-refresh-btn::after { border: none; }
.ai-refresh-btn:active { opacity: 0.7; }

.ai-event-item {
  display: flex;
  gap: 20rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}
.ai-event-item:last-child { border-bottom: none; }

.ai-event-year {
  flex-shrink: 0;
  font-size: 22rpx;
  font-weight: 700;
  color: #f43f5e;
  background: #fff1f2;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  height: fit-content;
}

.ai-event-body { flex: 1; }

.ai-event-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #1e293b;
  display: block;
  margin-bottom: 4rpx;
}

.ai-event-content {
  font-size: 22rpx;
  color: #64748b;
  display: block;
  line-height: 1.6;
}

/* Notify toggle card */
.notify-card {
  padding: 24rpx 32rpx;
}

.notify-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.notify-left {
  flex: 1;
  margin-right: 16rpx;
}

.notify-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
  display: block;
}

.notify-sub {
  font-size: 22rpx;
  color: #94a3b8;
  display: block;
  margin-top: 6rpx;
  line-height: 1.5;
}

.notify-switch {
  flex-shrink: 0;
}

.notify-tip {
  margin-top: 20rpx;
  padding: 16rpx 20rpx;
  background: #fef3c7;
  border-radius: 12rpx;
}

.notify-tip-text {
  font-size: 24rpx;
  color: #d97706;
}

/* Footer */
.form-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(255,255,255,0.9);
  backdrop-filter: blur(20rpx);
  border-top: 1rpx solid rgba(0,0,0,0.06);
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 16rpx;
}

.delete-btn-wrap { flex-shrink: 0; }

.flex-btn { flex: 1; }

.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  color: #94a3b8;
  font-size: 28rpx;
}
