<view class="fortune-page">
  <scroll-view class="fortune-scroll" scroll-y>

    <!-- 设置区域 -->
    <view class="setting-card">

      <!-- 生日选择 -->
      <view class="field-row field-row--birthday">
        <view class="birthday-header">
          <text class="field-label">我的生日</text>
          <!-- 公历 / 农历 切换 -->
          <view class="cal-toggle">
            <view class="cal-btn {{calType==='solar' ? 'cal-btn--active' : ''}}" bindtap="onCalTypeSolar">公历</view>
            <view class="cal-btn {{calType==='lunar' ? 'cal-btn--active' : ''}}" bindtap="onCalTypeLunar">农历</view>
          </view>
        </view>

        <!-- 公历选择器 -->
        <picker wx:if="{{calType==='solar'}}" mode="date" value="{{solarBirthday}}" end="{{queryDate}}" bindchange="onSolarBirthdayChange">
          <view class="field-value-row">
            <text class="field-value {{solarBirthday ? '' : 'placeholder'}}">
              {{solarBirthday || '点击选择公历生日'}}
            </text>
            <text class="field-icon-cal">🎂</text>
          </view>
        </picker>

        <!-- 农历选择器 -->
        <picker wx:else mode="multiSelector" value="{{lunarPickerValue}}" range="{{lunarPickerRange}}" bindchange="onLunarBirthdayChange">
          <view class="field-value-row">
            <text class="field-value {{lunarBirthdayDisplay ? '' : 'placeholder'}}">
              {{lunarBirthdayDisplay || '点击选择农历生日'}}
            </text>
            <text class="field-icon-cal">🎂</text>
          </view>
        </picker>
      </view>

      <!-- 自动推算的星座（只读展示） -->
      <view class="field-divider" />
      <view class="field-row field-row-sign">
        <text class="field-label">我的星座</text>
        <view class="field-value-row">
          <view wx:if="{{currentSign}}" class="sign-display">
            <text class="sign-display-emoji">{{signData[currentSign].emoji}}</text>
            <text class="sign-display-name">{{currentSign}}</text>
            <text class="sign-display-range">{{signData[currentSign].dateRange}}</text>
          </view>
          <text wx:else class="field-value placeholder">生日后自动显示</text>
        </view>
      </view>

      <view class="field-divider" />

      <!-- 日期选择 -->
      <view class="field-row">
        <text class="field-label">查询日期</text>
        <picker mode="date" value="{{queryDate}}" bindchange="onDateChange">
          <view class="field-value-row">
            <text class="field-value">{{queryDate}}</text>
            <text class="field-icon-cal">📅</text>
          </view>
        </picker>
      </view>

    </view>

    <!-- 农历提示 -->
    <view wx:if="{{calType==='lunar' && currentSign}}" class="lunar-tip-banner">
      <text class="lunar-tip-icon">ℹ️</text>
      <text class="lunar-tip-text">星座依据农历对应的公历日期推算，供参考</text>
    </view>

    <!-- 未设置生日提示 -->
    <view wx:if="{{!myBirthday}}" class="tip-banner">
      <text class="tip-banner-icon">💡</text>
      <text class="tip-banner-text">设置您的生日，即可自动匹配星座并查看专属运势</text>
    </view>

    <!-- 生成按钮 -->
    <view class="generate-btn {{loading ? 'loading' : ''}} {{!currentSign ? 'disabled' : ''}}"
          bindtap="queryFortune">
      <text>{{loading ? '正在生成…' : '生成今日运势'}}</text>
    </view>

    <!-- 错误提示 -->
    <view wx:if="{{error}}" class="error-card">
      <text class="error-icon">⚠️</text>
      <text class="error-text">{{error}}</text>
    </view>

    <!-- 运势内容 -->
    <block wx:if="{{fortune}}">

      <!-- 星座标题 -->
      <view class="result-header">
        <text class="result-sign-emoji">{{signData[currentSign].emoji}}</text>
        <view class="result-sign-info">
          <text class="result-sign-name">{{currentSign}}</text>
          <text class="result-date">{{queryDate}} 运势</text>
        </view>
      </view>

      <!-- 今日总运 -->
      <view class="content-card">
        <view class="card-title-row">
          <view class="card-title-bar" />
          <text class="card-title">今日总运</text>
        </view>
        <text class="summary-text">{{fortune.summary}}</text>
        <view wx:if="{{fortune.tip}}" class="tip-row">
          <text class="tip-label">💡 今日小贴士</text>
          <text class="tip-text">{{fortune.tip}}</text>
        </view>
      </view>

      <!-- 四维指数 -->
      <view class="content-card">
        <view class="card-title-row">
          <view class="card-title-bar" />
          <text class="card-title">四维指数</text>
        </view>
        <view class="index-list">
          <view class="index-item" wx:for="{{indices}}" wx:key="key">
            <view class="index-header-row">
              <view class="index-left">
                <text class="index-emoji">{{item.emoji}}</text>
                <text class="index-name">{{item.name}}</text>
              </view>
              <text class="index-score" style="color:{{item.color}}">{{item.score}}<text class="index-unit">分</text></text>
            </view>
            <view class="index-bar-bg">
              <view class="index-bar-fill" style="width:{{item.score}}%;background:{{item.color}}" />
            </view>
            <text class="index-desc">{{item.desc}}</text>
          </view>
        </view>
      </view>

      <!-- 星座特点 -->
      <view class="content-card" wx:if="{{currentSign}}">
        <view class="card-title-row">
          <view class="card-title-bar" />
          <text class="card-title">星座特点</text>
        </view>
        <view class="traits-grid">
          <view class="trait-item">
            <text class="trait-label">四象属性</text>
            <text class="trait-value">{{signData[currentSign].element}}</text>
          </view>
          <view class="trait-item">
            <text class="trait-label">掌管宫位</text>
            <text class="trait-value">{{signData[currentSign].house}}</text>
          </view>
          <view class="trait-item">
            <text class="trait-label">阴阳属性</text>
            <text class="trait-value">{{signData[currentSign].yinyang}}</text>
          </view>
          <view class="trait-item">
            <text class="trait-label">最大特征</text>
            <text class="trait-value">{{signData[currentSign].trait}}</text>
          </view>
          <view class="trait-item">
            <text class="trait-label">主管行星</text>
            <text class="trait-value">{{signData[currentSign].planet}}</text>
          </view>
          <view class="trait-item">
            <text class="trait-label">幸运颜色</text>
            <text class="trait-value">{{signData[currentSign].color}}</text>
          </view>
          <view class="trait-item">
            <text class="trait-label">吉祥饰物</text>
            <text class="trait-value">{{signData[currentSign].talisman}}</text>
          </view>
          <view class="trait-item">
            <text class="trait-label">幸运号码</text>
            <text class="trait-value">{{signData[currentSign].number}}</text>
          </view>
          <view class="trait-item">
            <text class="trait-label">开运金属</text>
            <text class="trait-value">{{signData[currentSign].metal}}</text>
          </view>
        </view>
      </view>

      <!-- 今日穿搭 -->
      <view class="content-card" wx:if="{{fortune.outfit}}">
        <view class="card-title-row">
          <view class="card-title-bar" />
          <text class="card-title">今日穿搭推荐</text>
        </view>
        <view class="outfit-box">
          <text class="outfit-icon">👗</text>
          <text class="outfit-text">{{fortune.outfit}}</text>
        </view>
      </view>

      <!-- 免责声明 -->
      <view class="disclaimer">
        <text class="disclaimer-text">内容仅供娱乐参考，请理性看待。</text>
      </view>

    </block>

    <view style="height:60rpx" />
  </scroll-view>
</view>
