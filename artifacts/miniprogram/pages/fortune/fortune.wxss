.fortune-page {
  min-height: 100vh;
  background: #f8fafc;
}
.fortune-scroll { height: 100vh; }

/* ── 设置卡片 ─────────────────────────────────────── */
.setting-card {
  margin: 24rpx 24rpx 0;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.field-row {
  display: flex;
  align-items: center;
  padding: 32rpx 28rpx;
}
.field-label {
  font-size: 28rpx;
  color: #1e293b;
  width: 140rpx;
  flex-shrink: 0;
}
.field-value-row {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  line-height: 0px;
}
.field-value {
  font-size: 28rpx;
  color: #334155;
}
.field-value.placeholder { color: #94a3b8; }
.field-arrow {
  font-size: 22rpx;
  color: #94a3b8;
  margin-left: 8rpx;
}
.field-icon-cal {
  font-size: 28rpx;
}
.field-divider {
  height: 1rpx;
  background: #f1f5f9;
  margin: 0 28rpx;
}

/* ── 生成按钮 ─────────────────────────────────────── */
.generate-btn {
  margin: 28rpx 24rpx 0;
  background: #f43f5e;
  border-radius: 16rpx;
  padding: 30rpx 0;
  text-align: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 2rpx;
}
.generate-btn.loading { opacity: 0.65; }
.generate-btn.disabled { opacity: 0.4; }
.generate-btn:active { opacity: 0.8; }

/* ── 结果头部 ─────────────────────────────────────── */
.result-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin: 32rpx 24rpx 0;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.result-sign-emoji { font-size: 64rpx; }
.result-sign-info { flex: 1; }
.result-sign-name {
  font-size: 36rpx;
  font-weight: 800;
  color: #1e293b;
  display: block;
  margin-bottom: 6rpx;
}
.result-date { font-size: 24rpx; color: #94a3b8; display: block; }

/* ── 内容卡片通用 ─────────────────────────────────── */
.content-card {
  margin: 20rpx 24rpx 0;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.card-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
}
.card-title-bar {
  width: 6rpx;
  height: 32rpx;
  background: #f43f5e;
  border-radius: 4rpx;
}
.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1e293b;
}

/* ── 今日总运 ─────────────────────────────────────── */
.summary-text {
  font-size: 27rpx;
  color: #475569;
  line-height: 1.85;
  display: block;
}
.tip-row {
  margin-top: 20rpx;
  background: #fff7f8;
  border-radius: 12rpx;
  padding: 18rpx 20rpx;
  border-left: 4rpx solid #f43f5e;
}
.tip-label {
  font-size: 22rpx;
  color: #f43f5e;
  font-weight: 600;
  display: block;
  margin-bottom: 6rpx;
}
.tip-text { font-size: 25rpx; color: #475569; line-height: 1.7; }

/* ── 四维指数 ─────────────────────────────────────── */
.index-list { display: flex; flex-direction: column; gap: 28rpx; }
.index-item {}
.index-header-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}
.index-left { display: flex; align-items: center; gap: 10rpx; }
.index-emoji { font-size: 30rpx; }
.index-name { font-size: 28rpx; color: #1e293b; font-weight: 600; }
.index-score { font-size: 34rpx; font-weight: 800; }
.index-unit { font-size: 20rpx; font-weight: 400; color: #94a3b8; margin-left: 2rpx; }
.index-bar-bg {
  height: 14rpx;
  background: #f1f5f9;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 10rpx;
}
.index-bar-fill {
  height: 100%;
  border-radius: 8rpx;
}
.index-desc { font-size: 24rpx; color: #64748b; }

/* ── 星座特点 ─────────────────────────────────────── */
.traits-grid {
  display: flex;
  flex-wrap: wrap;
  margin: -8rpx;
}
.trait-item {
  width: 50%;
  box-sizing: border-box;
  padding: 8rpx;
}
.trait-item-wide {
  width: 100%;
}
.trait-label {
  font-size: 20rpx;
  color: #94a3b8;
  display: block;
  margin-bottom: 8rpx;
  background: #f8fafc;
  border-radius: 12rpx 12rpx 0 0;
  padding: 14rpx 18rpx 0;
  border: 1rpx solid #e2e8f0;
  border-bottom: none;
}
.trait-value {
  font-size: 26rpx;
  color: #1e293b;
  font-weight: 600;
  display: block;
  background: #f8fafc;
  border-radius: 0 0 12rpx 12rpx;
  padding: 0 18rpx 14rpx;
  border: 1rpx solid #e2e8f0;
  border-top: none;
}

/* ── 穿搭推荐 ─────────────────────────────────────── */
.outfit-box {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  background: #fff7f8;
  border-radius: 12rpx;
  padding: 20rpx;
  border: 1rpx solid rgba(244,63,94,0.12);
}
.outfit-icon { font-size: 40rpx; flex-shrink: 0; margin-top: 2rpx; }
.outfit-text { font-size: 26rpx; color: #475569; line-height: 1.8; flex: 1; }

/* ── 免责声明 ─────────────────────────────────────── */
.disclaimer {
  margin: 20rpx 24rpx 0;
  padding: 20rpx 24rpx;
  background: #fff;
  border-radius: 14rpx;
  border: 1rpx dashed #e2e8f0;
}
.disclaimer-text {
  font-size: 21rpx;
  color: #94a3b8;
  line-height: 1.7;
  display: block;
  text-align: center;
}

/* ── 错误 ─────────────────────────────────────── */
.error-card {
  margin: 20rpx 24rpx 0;
  padding: 28rpx;
  background: #fff1f2;
  border-radius: 16rpx;
  border: 1rpx solid rgba(244,63,94,0.2);
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}
.error-icon { font-size: 28rpx; }
.error-text { font-size: 26rpx; color: #be123c; flex: 1; line-height: 1.6; }

/* ── 生日行（带公历/农历切换） ───────────────────── */
.field-row--birthday {
  flex-direction: column;
  align-items: stretch;
  padding: 24rpx 28rpx 20rpx;
}
.birthday-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}
.cal-toggle {
  display: flex;
  background: #f1f5f9;
  border-radius: 14rpx;
  padding: 4rpx;
  gap: 4rpx;
}
.cal-btn {
  padding: 10rpx 28rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.4;
}
.cal-btn--active {
  background: #fff;
  color: #f43f5e;
  font-weight: 700;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.10);
}

/* ── 农历说明提示 ─────────────────────────────────── */
.lunar-tip-banner {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin: 14rpx 24rpx 0;
  background: #f0f9ff;
  border: 1rpx solid rgba(56,189,248,0.25);
  border-radius: 12rpx;
  padding: 14rpx 18rpx;
}
.lunar-tip-icon { font-size: 24rpx; flex-shrink: 0; }
.lunar-tip-text { font-size: 22rpx; color: #0369a1; line-height: 1.5; }

/* ── 星座自动展示行 ───────────────────────────────── */
.field-row-sign { cursor: default; }
.sign-display {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.sign-display-emoji { font-size: 36rpx; }
.sign-display-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #f43f5e;
}
.sign-display-range {
  font-size: 22rpx;
  color: #94a3b8;
  margin-left: 4rpx;
}

/* ── 提示横幅 ─────────────────────────────────────── */
.tip-banner {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin: 16rpx 24rpx 0;
  background: #fffbeb;
  border: 1rpx solid rgba(245,158,11,0.25);
  border-radius: 14rpx;
  padding: 18rpx 20rpx;
}
.tip-banner-icon { font-size: 28rpx; flex-shrink: 0; }
.tip-banner-text { font-size: 24rpx; color: #92400e; line-height: 1.6; }
