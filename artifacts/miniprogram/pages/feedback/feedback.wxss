.feedback-page {
  min-height: 100vh;
  background: #f8fafc;
  padding: 24rpx;
  box-sizing: border-box;
}

.form-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 16rpx;
}

.required {
  color: #f43f5e;
}

.form-textarea {
  width: 100%;
  min-height: 280rpx;
  font-size: 28rpx;
  color: #334155;
  line-height: 1.6;
  box-sizing: border-box;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background: #f8fafc;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.char-count {
  display: block;
  text-align: right;
  font-size: 22rpx;
  color: #94a3b8;
  margin-top: 12rpx;
}

.submit-btn {
  margin-top: 16rpx;
  background: linear-gradient(135deg, #fb7185, #f43f5e);
  color: #fff;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 600;
  padding: 24rpx 0;
}

.submit-btn::after {
  border: none;
}

.form-tip {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: #94a3b8;
  margin-top: 24rpx;
}

.form-label-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.form-label-sub {
  font-size: 22rpx;
  color: #94a3b8;
}

.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item,
.image-add {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  position: relative;
  overflow: hidden;
}

.image-preview {
  width: 100%;
  height: 100%;
  display: block;
}

.image-remove {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.55);
  color: #fff;
  font-size: 28rpx;
  line-height: 40rpx;
  text-align: center;
}

.image-add {
  border: 2rpx dashed #e2e8f0;
  background: #f8fafc;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.image-add-icon {
  font-size: 48rpx;
  color: #94a3b8;
  line-height: 1;
}

.image-add-text {
  font-size: 22rpx;
  color: #94a3b8;
}
