.page {
  min-height: 100vh;
  background: #f8fafc;
  padding: 24rpx 24rpx 0;
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 8rpx;
}

.section-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #f43f5e;
  padding: 28rpx 8rpx 12rpx;
  letter-spacing: 0.5rpx;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 26rpx 32rpx;
  min-height: 88rpx;
}

.divider {
  height: 1rpx;
  background: #f1f5f9;
  margin: 0 32rpx;
}

.label {
  font-size: 28rpx;
  color: #475569;
  font-weight: 500;
  flex-shrink: 0;
  width: 160rpx;
}

/* Date picker */
.picker-val {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.picker-text {
  font-size: 30rpx;
  color: #1e293b;
  font-weight: 500;
}

.picker-icon {
  font-size: 32rpx;
}

/* Result */
.result {
  font-size: 30rpx;
  font-weight: 600;
  color: #f43f5e;
  text-align: right;
}

.result-highlight {
  color: #f97316;
}

.result-past {
  font-size: 28rpx;
  color: #94a3b8;
  font-weight: 500;
}

.result-col {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
}

.result-sub {
  font-size: 22rpx;
  color: #94a3b8;
  font-weight: 400;
}

.unit-inline {
  font-size: 22rpx;
  font-weight: 400;
  color: #94a3b8;
  margin-left: 4rpx;
}

/* Elapsed timer */
.elapsed-val {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
  flex: 1;
  justify-content: flex-end;
  flex-wrap: wrap;
}

.elapsed-num {
  font-size: 32rpx;
  font-weight: 700;
  color: #f43f5e;
  font-variant-numeric: tabular-nums;
  min-width: 28rpx;
  text-align: right;
}

.elapsed-unit {
  font-size: 22rpx;
  color: #94a3b8;
  margin-right: 8rpx;
}

/* Copy button */
.copy-btn {
  margin: 32rpx 0 16rpx;
  width: 100%;
  background: #f43f5e;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 20rpx;
  padding: 28rpx 0;
  border: none;
  box-shadow: 0 4rpx 20rpx rgba(244, 63, 94, 0.25);
  letter-spacing: 1rpx;
}

.copy-btn::after {
  border: none;
}
