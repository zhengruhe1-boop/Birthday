/* ══════════════════════════════════════════════════════
   登录页 · 全局
══════════════════════════════════════════════════════ */
.login-page {
  min-height: 100vh;
  background: #fff;
  display: flex;
  flex-direction: column;
  position: relative;
  overflow: hidden;
}

/* ── 检查会话状态的全屏 loading ── */
.session-checking {
  position: fixed;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(160deg, #fff5f7 0%, #fff9f0 100%);
  gap: 24rpx;
}

.session-checking .logo-emoji {
  font-size: 100rpx;
}

.checking-text {
  font-size: 40rpx;
  font-weight: 700;
  color: #f43f5e;
  letter-spacing: 4rpx;
}

/* ── 背景装饰圆 ── */
.login-bg {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  pointer-events: none;
  z-index: 0;
}
.bg-circle {
  position: absolute;
  border-radius: 50%;
}
.bg-circle-1 {
  width: 500rpx;
  height: 500rpx;
  background: radial-gradient(circle, rgba(244,63,94,0.12) 0%, transparent 70%);
  top: -100rpx;
  right: -120rpx;
}
.bg-circle-2 {
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(249,115,22,0.10) 0%, transparent 70%);
  top: 200rpx;
  left: -150rpx;
}
.bg-circle-3 {
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(244,63,94,0.08) 0%, transparent 70%);
  bottom: 200rpx;
  right: -60rpx;
}

/* ══════════════════════════════════════════════════════
   第一步：登录
══════════════════════════════════════════════════════ */

/* Hero */
.login-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: calc(120rpx + env(safe-area-inset-top));
  padding-bottom: 60rpx;
  position: relative;
  z-index: 1;
}

.logo-wrap {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #f43f5e 0%, #fb923c 100%);
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 48rpx rgba(244,63,94,0.30);
  margin-bottom: 32rpx;
}
.logo-emoji { font-size: 80rpx; line-height: 1; }

.app-name {
  font-size: 56rpx;
  font-weight: 800;
  color: #1e293b;
  letter-spacing: 4rpx;
  display: block;
  margin-bottom: 12rpx;
}
.app-tagline {
  font-size: 26rpx;
  color: #94a3b8;
  display: block;
}

/* 登录卡片 */
.login-card {
  margin: 0 40rpx;
  background: #fff;
  border-radius: 36rpx;
  padding: 48rpx 40rpx 40rpx;
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.08);
  position: relative;
  z-index: 1;
}

/* 错误提示 */
.error-box {
  background: #fff1f2;
  border: 1rpx solid #fda4af;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 28rpx;
}
.error-text {
  font-size: 24rpx;
  color: #e11d48;
  line-height: 1.6;
}

/* 微信登录按钮 */
.wx-login-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #f43f5e 0%, #fb923c 100%);
  border-radius: 28rpx;
  border: none;
  padding: 0;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(244,63,94,0.35);
}
.wx-login-btn::after { border: none; }
.wx-login-btn.loading { opacity: 0.7; }
.wx-login-btn:active { opacity: 0.85; }

.wx-btn-inner {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  height: 100%;
}
.wx-icon { font-size: 36rpx; line-height: 1; }
.wx-btn-text { font-size: 32rpx; font-weight: 700; color: #fff; }

/* 协议说明（点击登录即同意，无需勾选）*/
.agree-row {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: center;
  gap: 0;
}
.agree-text { font-size: 24rpx; color: #94a3b8; }
.agree-link { font-size: 24rpx; color: #f43f5e; font-weight: 500; }

/* 安全说明 */
.security-tips {
  margin: 48rpx 40rpx 0;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  position: relative;
  z-index: 1;
}
.tip-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.tip-icon { font-size: 24rpx; }
.tip-text { font-size: 22rpx; color: #94a3b8; }

/* ══════════════════════════════════════════════════════
   法律协议弹窗
══════════════════════════════════════════════════════ */
.modal-mask {
  position: fixed;
  top: 0; left: 0;
  width: 100%; height: 100%;
  background: rgba(0,0,0,0.5);
  z-index: 100;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}
.modal-sheet {
  background: #fff;
  border-radius: 36rpx 36rpx 0 0;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}
.modal-handle {
  width: 60rpx;
  height: 8rpx;
  background: #e2e8f0;
  border-radius: 4rpx;
  margin: 20rpx auto 0;
}
.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 40rpx;
  border-bottom: 1rpx solid #f1f5f9;
}
.modal-title { font-size: 32rpx; font-weight: 700; color: #1e293b; }
.modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  color: #94a3b8;
  font-size: 28rpx;
}
.modal-close:active { background: #f1f5f9; }
.modal-body { flex: 1; padding: 32rpx 40rpx; }
.modal-text {
  font-size: 26rpx;
  color: #475569;
  line-height: 1.8;
  white-space: pre-wrap;
  word-break: break-all;
  display: block;
}
.modal-loading { display: flex; align-items: center; justify-content: center; padding: 60rpx 0; }
.modal-loading-text { font-size: 26rpx; color: #94a3b8; }
.modal-footer { padding: 16rpx 40rpx 0; }
.modal-ok-btn {
  width: 100%;
  height: 88rpx;
  background: #f43f5e;
  border-radius: 24rpx;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
}
.modal-ok-btn::after { border: none; }
.modal-ok-btn:active { opacity: 0.85; }
