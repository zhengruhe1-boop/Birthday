.login-page {
  min-height: 100vh;
  background: linear-gradient(160deg, #fff1f2 0%, #fff 50%, #fafafa 100%);
  display: flex;
  flex-direction: column;
  padding-bottom: env(safe-area-inset-bottom);
}

.login-bg {
  position: fixed;
  top: 0; left: 0; right: 0;
  height: 50vh;
  background: linear-gradient(135deg, rgba(244,63,94,0.08) 0%, rgba(251,113,133,0.04) 100%);
  pointer-events: none;
}

.login-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 48rpx 48rpx;
}

.logo-wrap {
  width: 160rpx;
  height: 160rpx;
  background: #fff;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 48rpx rgba(244,63,94,0.15);
  margin-bottom: 32rpx;
  font-size: 80rpx;
}

.app-title {
  font-size: 64rpx;
  font-weight: 800;
  color: #1e293b;
  letter-spacing: -1rpx;
  margin-bottom: 12rpx;
}

.app-subtitle {
  font-size: 28rpx;
  color: #94a3b8;
}

.login-cards {
  flex: 1;
  padding: 0 32rpx;
}

.login-card {
  background: rgba(255,255,255,0.9);
  backdrop-filter: blur(20rpx);
  border-radius: 32rpx;
  padding: 40rpx;
  border: 1rpx solid rgba(0,0,0,0.06);
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.06);
  margin-bottom: 24rpx;
}

.card-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.card-icon { font-size: 36rpx; }

.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1e293b;
}

.card-desc {
  font-size: 24rpx;
  color: #94a3b8;
  display: block;
  margin-bottom: 32rpx;
  line-height: 1.6;
}

.legal-footer {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 48rpx 32rpx;
  flex-wrap: wrap;
}

.legal-text { font-size: 22rpx; color: #94a3b8; }

.legal-link {
  font-size: 22rpx;
  color: #f43f5e;
  text-decoration: underline;
}

/* Modal */
.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.4);
  z-index: 100;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.modal-sheet {
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  padding-bottom: env(safe-area-inset-bottom);
}

.modal-handle {
  width: 80rpx;
  height: 8rpx;
  background: #e2e8f0;
  border-radius: 4rpx;
  margin: 16rpx auto 0;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 40rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.modal-title { font-size: 32rpx; font-weight: 600; }

.modal-close {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #f1f5f9;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #64748b;
}

.modal-body {
  flex: 1;
  padding: 32rpx 40rpx;
  max-height: 50vh;
}

.modal-text {
  font-size: 26rpx;
  color: #374151;
  line-height: 1.8;
  display: block;
  white-space: pre-wrap;
}

.modal-empty {
  font-size: 26rpx;
  color: #94a3b8;
  display: block;
  text-align: center;
  padding: 80rpx 0;
}

.modal-footer {
  padding: 16rpx 40rpx 24rpx;
  border-top: 1rpx solid #f1f5f9;
}
