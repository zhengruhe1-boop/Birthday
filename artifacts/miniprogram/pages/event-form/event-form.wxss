.form-page {
  min-height: 100vh;
  background: #f8fafc;
  display: flex;
  flex-direction: column;
}

.form-scroll { height: 100vh; }

.form-body { padding: 24rpx 32rpx; }

.form-card {
  background: #fff;
  border-radius: 24rpx;
  border: 1rpx solid rgba(0,0,0,0.06);
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.field-group { margin-bottom: 28rpx; }
.field-group:last-child { margin-bottom: 0; }

.label {
  font-size: 26rpx;
  font-weight: 500;
  color: #1e293b;
  margin-bottom: 12rpx;
  display: block;
}
.label-required { color: #ef4444; margin-left: 4rpx; }
.label-optional { font-size: 22rpx; color: #94a3b8; font-weight: 400; margin-left: 8rpx; }

.input-field {
  width: 100%;
  height: 88rpx;
  border: 1rpx solid #e2e8f0;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #1e293b;
  background: #fafafa;
}

.field-hint {
  font-size: 22rpx;
  color: #94a3b8;
  display: block;
  margin-top: 10rpx;
  line-height: 1.6;
}

.picker-field {
  height: 88rpx;
  border: 1rpx solid #e2e8f0;
  border-radius: 16rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 28rpx;
  color: #1e293b;
  background: #fafafa;
}
.picker-arrow { color: #94a3b8; font-size: 32rpx; }

/* Preview card */
.preview-card {
  border-radius: 24rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.preview-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
}

.preview-body { flex: 1; min-width: 0; }

.preview-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.preview-sub {
  font-size: 22rpx;
  color: #64748b;
  display: block;
  margin-top: 4rpx;
}

/* Notify toggle card */
.notify-card {
  padding: 24rpx 32rpx;
}

.notify-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.notify-left {
  flex: 1;
  margin-right: 16rpx;
}

.notify-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
  display: block;
}

.notify-sub {
  font-size: 22rpx;
  color: #94a3b8;
  display: block;
  margin-top: 6rpx;
  line-height: 1.5;
}

.notify-switch {
  flex-shrink: 0;
}

.notify-tip {
  margin-top: 20rpx;
  padding: 16rpx 20rpx;
  background: #fef3c7;
  border-radius: 12rpx;
}

.notify-tip-text {
  font-size: 24rpx;
  color: #d97706;
}

/* Footer */
.form-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(255,255,255,0.9);
  backdrop-filter: blur(20rpx);
  border-top: 1rpx solid rgba(0,0,0,0.06);
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 16rpx;
}

.delete-btn-wrap { flex-shrink: 0; }

.save-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 20rpx;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}
.save-btn:active { opacity: 0.8; }

.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 20rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}
.btn-primary { background: #f43f5e; color: #fff; }
.btn-danger { background: #fff0f0; color: #ef4444; border: 1rpx solid #fca5a5; width: 88rpx; }
.btn-disabled { opacity: 0.5; }
.btn:active { opacity: 0.75; }

.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  color: #94a3b8;
  font-size: 28rpx;
}

/* ─── 提醒时机 ──────────────────────────────────────────────────── */
.reminder-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
  margin-bottom: 24rpx;
}
.reminder-chip {
  padding: 12rpx 28rpx;
  border-radius: 40rpx;
  border: 1.5rpx solid #e2e8f0;
  background: #f8fafc;
  font-size: 26rpx;
  color: #64748b;
  line-height: 1.4;
}
.reminder-chip-on {
  background: #fff1f2;
  border-color: #f43f5e;
  color: #f43f5e;
  font-weight: 600;
}
.remind-time-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.remind-time-label {
  font-size: 26rpx;
  color: #475569;
}
.remind-picker {
  height: 72rpx;
  border: 1rpx solid #e2e8f0;
  border-radius: 12rpx;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: #fafafa;
  font-size: 26rpx;
  color: #1e293b;
  min-width: 140rpx;
}
.remind-hint {
  font-size: 22rpx;
  color: #94a3b8;
  display: block;
  margin-top: 16rpx;
}
