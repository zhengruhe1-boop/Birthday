<view class="form-page" wx:if="{{!loading}}">

  <scroll-view class="form-scroll" scroll-y>
    <view class="form-body">

      <!-- 主卡片：名称 + 类型特有字段 -->
      <view class="form-card">

        <!-- 名称 -->
        <view class="field-group">
          <text class="label">
            {{eventType === 'anniversary' ? '纪念日名称' : '事件名称'}}
            <text class="label-required">*</text>
          </text>
          <input class="input-field"
            placeholder="{{eventType === 'anniversary' ? '例如：结婚纪念日' : eventType === 'countdown' ? '例如：高考' : '例如：复查体检'}}"
            value="{{name}}" bindinput="onNameInput" />
        </view>

        <!-- 纪念日：日期 + 人物 -->
        <block wx:if="{{eventType === 'anniversary'}}">
          <view class="field-group">
            <text class="label">纪念日日期<text class="label-required">*</text></text>
            <picker mode="date" value="{{eventDate}}" bindchange="onDateChange">
              <view class="picker-field">
                <text>{{eventDate || '请选择日期'}}</text>
                <text class="picker-arrow">›</text>
              </view>
            </picker>
          </view>
          <view class="field-group">
            <text class="label">相关人物<text class="label-optional">（选填）</text></text>
            <input class="input-field" placeholder="例如：小明 & 小红"
              value="{{person}}" bindinput="onPersonInput" />
          </view>
        </block>

        <!-- 倒数日：事件日期 -->
        <block wx:if="{{eventType === 'countdown'}}">
          <view class="field-group">
            <text class="label">事件日期<text class="label-required">*</text></text>
            <picker mode="date" value="{{eventDate}}" bindchange="onDateChange">
              <view class="picker-field">
                <text>{{eventDate || '请选择日期'}}</text>
                <text class="picker-arrow">›</text>
              </view>
            </picker>
          </view>
        </block>

        <!-- 其它：提醒时间（日期 + 时间分两个 picker） -->
        <block wx:if="{{eventType === 'other'}}">
          <view class="field-group">
            <text class="label">提醒日期<text class="label-required">*</text></text>
            <picker mode="date" value="{{reminderDate}}" start="{{minDate}}" bindchange="onReminderDateChange">
              <view class="picker-field">
                <text>{{reminderDate || '请选择日期'}}</text>
                <text class="picker-arrow">›</text>
              </view>
            </picker>
          </view>
          <view class="field-group">
            <text class="label">提醒时间<text class="label-required">*</text></text>
            <picker mode="time" value="{{reminderTimeVal}}" bindchange="onReminderTimeValChange">
              <view class="picker-field">
                <text>{{reminderTimeVal || '08:00'}}</text>
                <text class="picker-arrow">›</text>
              </view>
            </picker>
          </view>
        </block>
      </view>

      <!-- 预览卡 -->
      <view class="preview-card" style="background:{{meta.bg}}" wx:if="{{name}}">
        <view class="preview-icon" style="background:#fff">
          <text style="color:{{meta.color}}">{{meta.icon}}</text>
        </view>
        <view class="preview-body">
          <text class="preview-name">{{name}}</text>
          <text class="preview-sub">
            {{eventType === 'anniversary' && eventDate ? eventDate + (person ? ' · ' + person : '') :
              eventType === 'countdown' && eventDate ? '目标日期：' + eventDate :
              eventType === 'other' && reminderTime ? '提醒时间：' + reminderTime :
              '填写完整后预览'}}
          </text>
        </view>
      </view>

      <!-- 消息通知开关 -->
      <view class="form-card notify-card">
        <view class="notify-row">
          <view class="notify-left">
            <text class="notify-label">消息通知</text>
            <text class="notify-sub">
              {{oaSubscribed ? '已关注公众号，日期临近将推送微信提醒' : '关注生日通公众号后可开启'}}
            </text>
          </view>
          <switch
            class="notify-switch"
            checked="{{notifyEnabled}}"
            bindchange="onNotifyToggle"
            color="#f43f5e"
          />
        </view>
        <view wx:if="{{!oaSubscribed}}" class="notify-tip" bindtap="goFollowOa">
          <text class="notify-tip-text">👆 点此了解如何关注公众号开通提醒</text>
        </view>
      </view>

      <!-- 邮件提醒 -->
      <view class="form-card">
        <view class="field-group">
          <text class="label">输入邮箱消息提醒</text>
          <input class="input-field" type="email" placeholder="输入邮箱（选填）"
            value="{{reminderEmail}}" bindinput="onEmailInput" />
        </view>
      </view>

      <!-- 微信消息提醒时机 -->
      <view class="form-card notify-card">
        <text class="label">微信消息提醒时机</text>
        <view class="reminder-chips">
          <view
            wx:for="{{reminderDayOptions}}"
            wx:key="value"
            class="reminder-chip {{item.selected ? 'reminder-chip-on' : ''}}"
            data-value="{{item.value}}"
            bindtap="onReminderDayToggle">
            {{item.label}}
          </view>
        </view>
        <view class="remind-time-row">
          <text class="remind-time-label">每天发送时间</text>
          <picker mode="selector" range="{{sendHours}}" value="{{reminderSendHour}}" bindchange="onReminderHourChange">
            <view class="remind-picker">
              <text>{{sendHours[reminderSendHour]}}</text>
              <text class="picker-arrow">›</text>
            </view>
          </picker>
        </view>
        <text class="remind-hint">优先级高于后台设置，至少保留一项</text>
      </view>

    </view>
    <view style="height:180rpx" />
  </scroll-view>

  <!-- Footer -->
  <view class="form-footer">
    <view wx:if="{{isEdit}}" class="delete-btn-wrap">
      <button class="btn btn-danger {{deleting ? 'btn-disabled' : ''}}"
        bindtap="handleDelete" disabled="{{deleting || saving}}">
        <text>🗑️</text>
      </button>
    </view>
    <button class="save-btn flex-btn {{(saving || deleting) ? 'btn-disabled' : ''}}"
      style="background:{{meta.color}}"
      bindtap="handleSave" disabled="{{saving || deleting}}">
      {{saving ? '保存中...' : (isEdit ? '保存' : '添加')}}
    </button>
  </view>

</view>

<view wx:if="{{loading}}" class="loading-wrap">
  <text>加载中...</text>
</view>
