.legal-page {
  min-height: 100vh;
  background: #f8fafc;
}

.legal-scroll {
  height: 100vh;
}

.legal-body {
  padding: 32rpx 36rpx 40rpx;
  display: flex;
  flex-direction: column;
}

.legal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1e293b;
  display: block;
  margin-bottom: 8rpx;
}

.legal-updated {
  font-size: 22rpx;
  color: #94a3b8;
  display: block;
  margin-bottom: 40rpx;
}

.legal-section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1e293b;
  display: block;
  margin-top: 36rpx;
  margin-bottom: 12rpx;
}

.legal-text {
  font-size: 26rpx;
  color: #475569;
  line-height: 1.8;
  display: block;
}
