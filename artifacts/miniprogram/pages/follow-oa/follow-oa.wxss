.page {
  min-height: 100vh;
  background: #f8fafc;
}

.scroll {
  height: 100vh;
}

/* Hero */
.hero {
  padding: 48rpx 32rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.hero-icon {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #f43f5e, #fb923c);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(244,63,94,0.25);
}

.hero-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1e293b;
}

/* Card */
.card {
  background: #fff;
  border-radius: 24rpx;
  border: 1rpx solid rgba(0,0,0,0.06);
  padding: 32rpx;
  margin: 0 32rpx 24rpx;
}

/* Alert row */
.alert-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.alert-icon {
  font-size: 32rpx;
}

.alert-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #d97706;
}

.alert-row--ok {
  background: #f0fdf4;
  border: 1rpx solid #bbf7d0;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 0;
}

.alert-text--ok {
  color: #16a34a;
}

.desc {
  font-size: 26rpx;
  color: #475569;
  line-height: 1.8;
  display: block;
}

/* Steps */
.steps-card {}

.steps-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #1e293b;
  margin-bottom: 24rpx;
  display: block;
}

.step-item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.step-item:last-child {
  margin-bottom: 0;
}

.step-num {
  flex-shrink: 0;
  width: 44rpx;
  height: 44rpx;
  background: #f43f5e;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
}

.step-text {
  font-size: 26rpx;
  color: #475569;
  line-height: 1.7;
  padding-top: 6rpx;
}

/* Image */
.img-card {}

.img-label {
  font-size: 24rpx;
  color: #64748b;
  display: block;
  margin-bottom: 20rpx;
}

.guide-img {
  width: 100%;
  border-radius: 16rpx;
  display: block;
}

/* Button */
.btn-wrap {
  padding: 0 32rpx;
  margin-top: 8rpx;
}

.back-btn {
  width: 100%;
  height: 96rpx;
  background: #f43f5e;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.back-btn:active {
  opacity: 0.85;
}
