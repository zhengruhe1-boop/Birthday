<view class="tools-page">

  <view class="tools-header">
    <text class="tools-title">实用小工具</text>
    <view class="tools-sub-row">
      <text class="tools-sub">简单实用解决身边的小麻烦，</text>
      <text class="tools-sub">已累计帮助{{totalUseCount}}人次</text>
    </view>
  </view>

  <scroll-view class="tools-scroll" scroll-y>

    <view wx:if="{{loadingTools}}" class="tools-loading">
      <text>加载中…</text>
    </view>

    <view wx:elif="{{toolGroups.length === 0}}" class="tools-empty">
      <text class="tools-empty-icon">🔧</text>
      <text class="tools-empty-text">暂无可用工具</text>
    </view>

    <block wx:else>
      <block wx:for="{{toolGroups}}" wx:for-item="group" wx:key="id">
        <view class="category-section">
          <view class="category-header">
            <text class="category-name"><text wx:if="{{group.icon}}">{{group.icon}} </text>{{group.name}}</text>
          </view>
          <view class="tool-grid">
            <view
              class="tool-item"
              wx:for="{{group.tools}}"
              wx:for-item="tool"
              wx:key="id"
              bindtap="tapDynamicTool"
              data-id="{{tool.id}}"
              data-type="{{tool.type}}"
              data-path="{{tool.path}}"
              data-app-id="{{tool.app_id}}"
              data-page-path="{{tool.page_path}}"
            >
              <view class="tool-icon-box">
                <view class="tool-icon-wrap">
                  <image wx:if="{{tool.iconIsUrl}}" src="{{tool.icon}}" class="tool-icon-img" mode="aspectFit" />
                  <text wx:else class="tool-icon-emoji">{{tool.icon}}</text>
                </view>
                <view wx:if="{{tool.type === 'external'}}" class="tool-external-tag">外部</view>
              </view>
              <text class="tool-name">{{tool.name}}</text>
            </view>
          </view>
        </view>
      </block>
    </block>

    <view style="height:40rpx" />
  </scroll-view>

</view>
