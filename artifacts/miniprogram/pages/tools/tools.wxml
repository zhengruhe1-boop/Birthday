    <!-- 内置工具区 -->
    <block wx:if="{{dateCalcEnabled || ageCalcEnabled || imgCompressEnabled}}">
      <!-- <view class="section-label" style="margin-top:40rpx">实用工具</view> -->
      <view class="tool-list">

        <block wx:if="{{dateCalcEnabled}}">
          <view class="tool-item" bindtap="goDateCalc">
            <view class="tool-icon blue-bg">
              <image wx:if="{{dateCalcIconIsUrl}}" src="{{dateCalcIcon}}" class="tool-icon-img" mode="aspectFill" />
              <text wx:else>{{dateCalcIcon}}</text>
            </view>
            <view class="tool-info">
              <text class="tool-name">日期计算器</text>
              <text class="tool-desc">计算日期间隔与前后日期</text>
            </view>
            <text class="tool-arrow">›</text>
          </view>
        </block>

        <block wx:if="{{ageCalcEnabled}}">
          <view class="tool-item" bindtap="goAgeCalc">
            <view class="tool-icon rose-bg">
              <image wx:if="{{ageCalcIconIsUrl}}" src="{{ageCalcIcon}}" class="tool-icon-img" mode="aspectFill" />
              <text wx:else>{{ageCalcIcon}}</text>
            </view>
            <view class="tool-info">
              <text class="tool-name">年龄计算器</text>
              <text class="tool-desc">生肖星座五行人生阶段一览</text>
            </view>
            <text class="tool-arrow">›</text>
          </view>
        </block>

        <block wx:if="{{imgCompressEnabled}}">
          <view class="tool-item" bindtap="goImgCompress">
            <view class="tool-icon green-bg">
              <image wx:if="{{imgCompressIconIsUrl}}" src="{{imgCompressIcon}}" class="tool-icon-img" mode="aspectFill" />
              <text wx:else>{{imgCompressIcon}}</text>
            </view>
            <view class="tool-info">
              <text class="tool-name">图片压缩</text>
              <text class="tool-desc">本地压缩，不上传服务器</text>
            </view>
            <text class="tool-arrow">›</text>
          </view>
        </block>

      </view>
    </block>

    <!-- 动态工具区 -->
    <block wx:if="{{dynamicTools.length > 0}}">

      <view class="section-label" style="margin-top:40rpx">更多工具</view>

      <view class="tool-list">
        <view
          class="tool-item"
          wx:for="{{dynamicTools}}"
          wx:key="id"
          bindtap="tapDynamicTool"
          data-tool="{{item}}"
        >
          <view class="tool-icon dynamic-icon-bg">
            <image wx:if="{{item.iconIsUrl}}" src="{{item.icon}}" class="tool-icon-img" mode="aspectFill" />
            <text wx:else>{{item.icon}}</text>
          </view>
          <view class="tool-info">
            <text class="tool-name">{{item.name}}</text>
            <text class="tool-desc">{{item.description}}</text>
          </view>
          <view class="tool-jump-badge" wx:if="{{item.type === 'external'}}">
            <text class="tool-jump-badge-text">外部</text>
          </view>
          <text class="tool-arrow" wx:else>›</text>
        </view>
      </view>

    </block>

    <view style="height:40rpx" />
  </scroll-view>

</view>
