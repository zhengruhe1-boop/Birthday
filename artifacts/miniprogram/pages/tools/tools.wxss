.tools-page {
  min-height: 100vh;
  background: #f8fafc;
}

.tools-header {
  padding: 40rpx 32rpx 28rpx;
  padding-top: calc(40rpx + env(safe-area-inset-top));
  background: linear-gradient(135deg, #fff5f7 0%, #fff9f0 100%);
  border-bottom: 1rpx solid rgba(244, 63, 94, 0.08);
}

.tools-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #1e293b;
}

.tools-sub-row {
  display: flex;
  flex-wrap: wrap;
  align-items: baseline;
  margin-top: 6rpx;
}

.tools-sub {
  font-size: 24rpx;
  color: #f43f5e;
  opacity: 0.7;
  line-height: 1.5;
}

.tools-scroll {
  height: calc(100vh - 160rpx);
  padding: 24rpx;
  box-sizing: border-box;
}

.category-section {
  background: #ffffff;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  padding: 28rpx 16rpx 12rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.category-header {
  margin-bottom: 20rpx;
  padding-left: 12rpx;
}

.category-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #f43f5e;
}

.tool-grid {
  display: flex;
  flex-wrap: wrap;
}

.tool-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 28rpx;
  box-sizing: border-box;
}

.tool-item:active {
  opacity: 0.75;
}

.tool-icon-box {
  position: relative;
  width: 96rpx;
  height: 96rpx;
  margin-bottom: 12rpx;
  flex-shrink: 0;
}

.tool-icon-wrap {
  width: 100%;
  height: 100%;
  border-radius: 24rpx;
  background: #fff1f2;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.tool-icon-img {
  width: 60rpx;
  height: 60rpx;
}

.tool-icon-emoji {
  font-size: 44rpx;
  line-height: 1;
}

.tool-name {
  font-size: 22rpx;
  color: #1e293b;
  text-align: center;
  max-width: 150rpx;
  line-height: 1.3;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  word-break: break-all;
}

.tool-external-tag {
  position: absolute;
  top: -6rpx;
  right: -10rpx;
  z-index: 2;
  padding: 2rpx 8rpx;
  border-radius: 999rpx;
  background: #f5f3ff;
  font-size: 16rpx;
  color: #7c3aed;
  line-height: 1.4;
  white-space: nowrap;
}

.tools-loading,
.tools-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: #94a3b8;
  font-size: 28rpx;
}

.tools-empty-icon {
  font-size: 72rpx;
  margin-bottom: 16rpx;
}

.tools-empty-text {
  font-size: 28rpx;
  color: #94a3b8;
}
