.profile-page {
  min-height: 100vh;
  background: #f8fafc;
}

.profile-scroll {
  height: 100vh;
}

/* User card */
.user-card {
  margin: 24rpx 24rpx 0;
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  margin-top: calc(24rpx + env(safe-area-inset-top));
}
.user-card:active { opacity: 0.85; }

.user-avatar-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  box-shadow: 0 0 0 4rpx rgba(244,63,94,0.15);
}

.user-avatar-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: block;
}

.user-info { flex: 1; min-width: 0; }

.user-name {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #1e293b;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.user-sub {
  display: block;
  font-size: 22rpx;
  color: #94a3b8;
  margin-top: 6rpx;
}

.user-arrow {
  color: #cbd5e1;
  font-size: 40rpx;
  flex-shrink: 0;
}

.group-label {
  font-size: 22rpx;
  color: #94a3b8;
  font-weight: 500;
  letter-spacing: 1rpx;
  padding: 32rpx 32rpx 12rpx;
  display: block;
}

/* Menu group */
.menu-group {
  margin: 0 24rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.menu-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #f1f5f9;
}
.menu-item:last-child { border-bottom: none; }
.menu-item:active { background: #f8fafc; }

.menu-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  flex-shrink: 0;
}
.bell-bg   { background: #fff1f2; }
.green-bg  { background: #f0fdf4; }
.wechat-bg { background: #f0fdf4; }
.blue-bg   { background: #eff6ff; }
.violet-bg { background: #f5f3ff; }
.gray-bg   { background: #f1f5f9; }
.slate-bg  { background: #f1f5f9; }
.orange-bg { background: #fff7ed; }

.unread-badge {
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  padding: 0 10rpx;
  border-radius: 16rpx;
  background: #f43f5e;
  color: #fff;
  font-size: 20rpx;
  font-weight: 600;
  text-align: center;
  flex-shrink: 0;
  margin-right: 4rpx;
}

.menu-name {
  flex: 1;
  font-size: 28rpx;
  font-weight: 500;
  color: #1e293b;
}

.menu-arrow {
  color: #cbd5e1;
  font-size: 40rpx;
  flex-shrink: 0;
}

.oa-badge {
  font-size: 20rpx;
  font-weight: 500;
  border-radius: 20rpx;
  padding: 4rpx 14rpx;
  flex-shrink: 0;
  margin-right: 4rpx;
}
.oa-badge--ok {
  background: #f0fdf4;
  color: #16a34a;
}
.oa-badge--no {
  background: #fff7ed;
  color: #ea580c;
}

/* Logout / Login */
.logout-wrap {
  margin: 40rpx 24rpx 0;
}

.logout-btn {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  text-align: center;
  border: 1rpx solid #fecdd3;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.logout-btn:active { opacity: 0.75; }
.logout-btn text {
  font-size: 28rpx;
  font-weight: 500;
  color: #f43f5e;
}

.login-btn {
  background: linear-gradient(135deg, #f43f5e, #fb923c);
  border-radius: 24rpx;
  padding: 28rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(244,63,94,0.25);
}
.login-btn:active { opacity: 0.85; }
.login-btn text {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
}

.footer-tip {
  text-align: center;
  margin-top: 48rpx;
}
.footer-tip text {
  font-size: 22rpx;
  color: #cbd5e1;
}

/* Wx profile modal (reused from home) */
.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.4);
  z-index: 100;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.modal-handle {
  width: 80rpx;
  height: 8rpx;
  background: #e2e8f0;
  border-radius: 4rpx;
  margin: 16rpx auto 0;
}

.wx-auth-sheet {
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 0 40rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

.wx-auth-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 24rpx;
}

.wx-auth-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1e293b;
  display: block;
  text-align: center;
}

.wx-auth-sub {
  font-size: 24rpx;
  color: #94a3b8;
  margin-top: 12rpx;
  display: block;
  text-align: center;
}

.wx-auth-field-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 28rpx;
  margin-top: 40rpx;
  width: 100%;
}

.wx-auth-field-row--nickname {
  align-items: center;
}

.wx-auth-field-label {
  font-size: 26rpx;
  color: #64748b;
  line-height: 1.5;
  flex-shrink: 0;
  width: 220rpx;
}

.wx-auth-avatar-btn {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
  padding: 0;
  margin: 0;
  margin-left: auto;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.wx-auth-avatar-btn::after { border: none; }
.wx-auth-avatar-btn:active { opacity: 0.8; }

.wx-auth-avatar-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: block;
}

.wx-auth-avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
}
.wx-auth-avatar-icon { font-size: 48rpx; display: block; }

.wx-auth-nickname-input {
  flex: 1;
  min-width: 0;
  height: 80rpx;
  line-height: 80rpx;
  background: #fff;
  border: 2rpx solid #e2e8f0;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #1e293b;
  box-sizing: border-box;
}
.wx-auth-nickname-ph { color: #cbd5e1; }

.wx-auth-confirm-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(90deg, #f43f5e 0%, #fb923c 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  border-radius: 999rpx;
  border: none;
  padding: 0;
  margin-top: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(244, 63, 94, 0.22);
}
.wx-auth-confirm-btn::after { border: none; }
.wx-auth-confirm-btn:active { opacity: 0.88; }

.wx-auth-skip-btn {
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  background: transparent;
  color: #64748b;
  font-size: 28rpx;
  border: none;
  padding: 0;
  margin-top: 8rpx;
}
.wx-auth-skip-btn::after { border: none; }
.wx-auth-skip-btn:active { opacity: 0.7; }

.wx-auth-logout-btn {
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  background: transparent;
  color: #ef4444;
  font-size: 28rpx;
  border: none;
  padding: 0;
  margin-top: 4rpx;
}
.wx-auth-logout-btn::after { border: none; }
.wx-auth-logout-btn:active { opacity: 0.7; }

/* 弹窗内偏好开关行 */
.modal-pref-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 40rpx;
  padding-top: 32rpx;
  border-top: 1rpx solid #f1f5f9;
}

.modal-pref-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}

.modal-pref-icon {
  font-size: 36rpx;
  line-height: 1;
}

.modal-pref-text {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.modal-pref-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
}

.modal-pref-sub {
  font-size: 22rpx;
  color: #94a3b8;
}
