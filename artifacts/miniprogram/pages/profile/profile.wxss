.profile-page {
  min-height: 100vh;
  background: #f8fafc;
}

.profile-scroll {
  height: 100vh;
}

/* User card */
.user-card {
  margin: 24rpx 24rpx 0;
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  margin-top: calc(24rpx + env(safe-area-inset-top));
}
.user-card:active { opacity: 0.85; }

.user-avatar-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  box-shadow: 0 0 0 4rpx rgba(244,63,94,0.15);
}

.user-avatar-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: block;
}

.user-info { flex: 1; min-width: 0; }

.user-name {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #1e293b;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.user-sub {
  display: block;
  font-size: 22rpx;
  color: #94a3b8;
  margin-top: 6rpx;
}

.user-arrow {
  color: #cbd5e1;
  font-size: 40rpx;
  flex-shrink: 0;
}

/* Group label */
/* 今日运势入口 */
.fortune-entry {
  margin: 24rpx 24rpx 0;
  background: linear-gradient(135deg, #fff1f2 0%, #fff7ed 100%);
  border: 1rpx solid rgba(244,63,94,0.18);
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  display: flex;
  align-items: center;
}
.fortune-entry:active { opacity: 0.8; }
.fortune-entry-left {
  display: flex;
  align-items: center;
  flex: 1;
  gap: 18rpx;
}
.fortune-entry-icon {
  font-size: 48rpx;
  width: 72rpx;
  text-align: center;
}
.fortune-entry-text { flex: 1; }
.fortune-entry-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1e293b;
  display: block;
  margin-bottom: 4rpx;
}
.fortune-entry-sub {
  font-size: 22rpx;
  color: #94a3b8;
  display: block;
}
.fortune-entry-arrow {
  font-size: 36rpx;
  color: #cbd5e1;
  margin-left: 8rpx;
}

.group-label {
  font-size: 22rpx;
  color: #94a3b8;
  font-weight: 500;
  letter-spacing: 1rpx;
  padding: 32rpx 32rpx 12rpx;
  display: block;
}

/* Menu group */
.menu-group {
  margin: 0 24rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.menu-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #f1f5f9;
}
.menu-item:last-child { border-bottom: none; }
.menu-item:active { background: #f8fafc; }

.menu-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  flex-shrink: 0;
}
.bell-bg   { background: #fff1f2; }
.green-bg  { background: #f0fdf4; }
.wechat-bg { background: #f0fdf4; }
.blue-bg   { background: #eff6ff; }
.violet-bg { background: #f5f3ff; }
.gray-bg   { background: #f1f5f9; }
.slate-bg  { background: #f1f5f9; }

.menu-name {
  flex: 1;
  font-size: 28rpx;
  font-weight: 500;
  color: #1e293b;
}

.menu-arrow {
  color: #cbd5e1;
  font-size: 40rpx;
  flex-shrink: 0;
}

.oa-badge {
  font-size: 20rpx;
  font-weight: 500;
  border-radius: 20rpx;
  padding: 4rpx 14rpx;
  flex-shrink: 0;
  margin-right: 4rpx;
}
.oa-badge--ok {
  background: #f0fdf4;
  color: #16a34a;
}
.oa-badge--no {
  background: #fff7ed;
  color: #ea580c;
}

/* Logout / Login */
.logout-wrap {
  margin: 40rpx 24rpx 0;
}

.logout-btn {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  text-align: center;
  border: 1rpx solid #fecdd3;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.logout-btn:active { opacity: 0.75; }
.logout-btn text {
  font-size: 28rpx;
  font-weight: 500;
  color: #f43f5e;
}

.login-btn {
  background: linear-gradient(135deg, #f43f5e, #fb923c);
  border-radius: 24rpx;
  padding: 28rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(244,63,94,0.25);
}
.login-btn:active { opacity: 0.85; }
.login-btn text {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
}

.footer-tip {
  text-align: center;
  margin-top: 48rpx;
}
.footer-tip text {
  font-size: 22rpx;
  color: #cbd5e1;
}

/* Wx profile modal (reused from home) */
.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.4);
  z-index: 100;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.modal-handle {
  width: 80rpx;
  height: 8rpx;
  background: #e2e8f0;
  border-radius: 4rpx;
  margin: 16rpx auto 0;
}

.wx-auth-sheet {
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 0 48rpx 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-bottom: calc(60rpx + env(safe-area-inset-bottom));
}

.wx-auth-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1e293b;
  margin-top: 40rpx;
  display: block;
  text-align: center;
}

.wx-auth-sub {
  font-size: 24rpx;
  color: #94a3b8;
  margin-top: 10rpx;
  display: block;
  text-align: center;
}

.wx-auth-step-row { width: 100%; margin-top: 32rpx; margin-bottom: 8rpx; }
.wx-auth-step-label { font-size: 24rpx; color: #94a3b8; }

.wx-auth-avatar-btn {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: hidden;
  background: #f1f5f9;
  border: none;
  padding: 0;
  margin-top: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.wx-auth-avatar-btn::after { border: none; }
.wx-auth-avatar-btn:active { opacity: 0.8; }

.wx-auth-avatar-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  display: block;
}

.wx-auth-avatar-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
}
.wx-auth-avatar-icon { font-size: 56rpx; display: block; }
.wx-auth-avatar-hint { font-size: 18rpx; color: #94a3b8; margin-top: 6rpx; display: block; }

.wx-auth-nickname-input {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
  border-radius: 20rpx;
  padding: 0 32rpx;
  font-size: 30rpx;
  color: #1e293b;
  margin-top: 36rpx;
  box-sizing: border-box;
}
.wx-auth-nickname-ph { color: #cbd5e1; }

.wx-auth-confirm-btn {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  background: linear-gradient(135deg, #f43f5e, #fb923c);
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  border-radius: 50rpx;
  border: none;
  padding: 0;
  margin-top: 32rpx;
}
.wx-auth-confirm-btn::after { border: none; }
.wx-auth-confirm-btn:active { opacity: 0.85; }

.wx-auth-skip-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: transparent;
  color: #94a3b8;
  font-size: 28rpx;
  border: none;
  padding: 0;
  margin-top: 16rpx;
}
.wx-auth-skip-btn::after { border: none; }
.wx-auth-skip-btn:active { opacity: 0.7; }
