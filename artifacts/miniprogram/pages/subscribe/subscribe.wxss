.subscribe-page {
  min-height: 100vh;
  background: #f8fafc;
  display: flex;
  flex-direction: column;
}

/* ── 导航栏 ── */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 96rpx 32rpx 20rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}
.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
}
.nav-back-icon {
  font-size: 56rpx;
  color: #374151;
  font-weight: 300;
  line-height: 1;
}
.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #111827;
}
.nav-placeholder {
  width: 64rpx;
}

/* ── 加载 ── */
.loading-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}
.loading-text {
  font-size: 28rpx;
  color: #9ca3af;
}

/* ── 插图区域 ── */
.hero-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 64rpx 40rpx 40rpx;
  background: #fff;
  margin-bottom: 24rpx;
}
.hero-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}
.hero-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 16rpx;
}
.hero-desc {
  font-size: 28rpx;
  color: #6b7280;
  text-align: center;
  line-height: 1.6;
  white-space: pre-line;
}

/* ── 状态卡片 ── */
.status-card {
  margin: 0 32rpx 24rpx;
  background: #fff;
  border-radius: 24rpx;
  border: 2rpx solid #e5e7eb;
  padding: 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  transition: border-color 0.2s;
}
.status-card.active {
  border-color: #a855f7;
  background: #faf5ff;
}
.status-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.status-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  flex-shrink: 0;
}
.status-dot.on {
  background: #a855f7;
}
.status-dot.off {
  background: #d1d5db;
}
.status-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 6rpx;
}
.status-sub {
  display: block;
  font-size: 24rpx;
  color: #6b7280;
}
.status-badge {
  font-size: 24rpx;
  font-weight: 600;
  padding: 8rpx 20rpx;
  border-radius: 100rpx;
  flex-shrink: 0;
}
.badge-on {
  background: #f3e8ff;
  color: #7c3aed;
}
.badge-off {
  background: #f3f4f6;
  color: #9ca3af;
}

/* ── 说明卡片 ── */
.tips-card {
  margin: 0 32rpx 40rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
}
.tips-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #374151;
  margin-bottom: 24rpx;
}
.tip-item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  margin-bottom: 20rpx;
}
.tip-item:last-child {
  margin-bottom: 0;
}
.tip-num {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #ede9fe;
  color: #7c3aed;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  text-align: center;
  line-height: 40rpx;
}
.tip-text {
  flex: 1;
  font-size: 26rpx;
  color: #4b5563;
  line-height: 1.6;
  padding-top: 6rpx;
}

/* ── 按钮区域 ── */
.action-wrap {
  padding: 0 32rpx 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}
.subscribe-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  background: linear-gradient(135deg, #a855f7, #7c3aed);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(124, 58, 237, 0.35);
}
.subscribe-btn.loading {
  opacity: 0.75;
}
.subscribe-btn[disabled] {
  opacity: 0.7;
}
.resubscribe-hint {
  font-size: 24rpx;
  color: #9ca3af;
}
