<view class="subscribe-page">

  <!-- 顶部导航栏 -->
  <view class="nav-bar">
    <view class="nav-back" bindtap="goBack">
      <text class="nav-back-icon">‹</text>
    </view>
    <text class="nav-title">生日提醒订阅</text>
    <view class="nav-placeholder" />
  </view>

  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading-wrap">
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 内容 -->
  <block wx:else>

    <!-- 插图区域 -->
    <view class="hero-section">
      <view class="hero-icon">🔔</view>
      <text class="hero-title">小程序订阅消息</text>
      <text class="hero-desc">授权后，当联系人生日临近时\n将通过小程序消息提醒你</text>
    </view>

    <!-- 状态卡片 -->
    <view class="status-card {{subscribed ? 'active' : ''}}">
      <view class="status-left">
        <view class="status-dot {{subscribed ? 'on' : 'off'}}" />
        <view class="status-text-wrap">
          <text class="status-title">{{subscribed ? '订阅已生效' : '暂未订阅'}}</text>
          <text class="status-sub">{{subscribed ? '剩余可接收次数：' + subscribeCount + ' 次' : '点击下方按钮授权'}}</text>
        </view>
      </view>
      <text class="status-badge {{subscribed ? 'badge-on' : 'badge-off'}}">
        {{subscribed ? '✓ 已开启' : '未开启'}}
      </text>
    </view>

    <!-- 说明列表 -->
    <view class="tips-card">
      <text class="tips-title">使用说明</text>
      <view class="tip-item">
        <text class="tip-num">1</text>
        <text class="tip-text">点击「授权订阅」，在弹窗中选择「允许」</text>
      </view>
      <view class="tip-item">
        <text class="tip-num">2</text>
        <text class="tip-text">每次授权可接收约 1 次通知，可多次授权累加次数</text>
      </view>
      <view class="tip-item">
        <text class="tip-num">3</text>
        <text class="tip-text">生日前提醒会自动发送到微信「服务通知」</text>
      </view>
      <view class="tip-item">
        <text class="tip-num">4</text>
        <text class="tip-text">管理员在后台配置提醒提前天数和发送时间</text>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-wrap">
      <button class="subscribe-btn {{requesting ? 'loading' : ''}}"
        bindtap="handleSubscribe" disabled="{{requesting}}">
        {{requesting ? '请在弹窗中操作...' : '授权订阅生日提醒'}}
      </button>
      <text wx:if="{{subscribed}}" class="resubscribe-hint">已订阅，再次点击可增加接收次数</text>
    </view>

  </block>

</view>
