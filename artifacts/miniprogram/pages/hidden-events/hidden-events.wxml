<view class="page">
  <scroll-view class="scroll" scroll-y>

    <view wx:if="{{loading}}" class="empty-wrap">
      <text class="empty-text">加载中...</text>
    </view>

    <block wx:elif="{{events.length === 0}}">
      <view class="empty-wrap">
        <text class="empty-icon">🙈</text>
        <text class="empty-title">暂无隐藏的生日</text>
        <text class="empty-sub">在添加/编辑页面关闭「展示到列表」即可隐藏</text>
      </view>
    </block>

    <block wx:else>
      <view class="tip-bar">
        <text>以下生日已隐藏，不在首页显示，通知不受影响。点击可编辑或取消隐藏。</text>
      </view>
      <view class="list">
        <view
          class="item"
          wx:for="{{events}}"
          wx:key="id"
          bindtap="goEdit"
          data-id="{{item.id}}"
        >
          <view class="item-avatar">
            <image wx:if="{{item.avatarUrl}}" class="item-avatar-img" src="{{item.avatarUrl}}" mode="aspectFill" />
            <text wx:else class="item-avatar-letter">{{item.name[0]}}</text>
          </view>
          <view class="item-body">
            <text class="item-name">{{item.name}}</text>
            <text class="item-sub">{{item.sub}}</text>
          </view>
          <view class="item-badge"><text>已隐藏</text></view>
          <text class="item-arrow">›</text>
        </view>
      </view>
    </block>

    <view style="height:60rpx" />
  </scroll-view>
</view>
