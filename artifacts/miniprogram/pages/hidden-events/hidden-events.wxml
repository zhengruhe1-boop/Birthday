<view class="page">
  <scroll-view class="scroll" scroll-y>

    <view wx:if="{{loading}}" class="empty-wrap">
      <text class="empty-text">加载中...</text>
    </view>

    <block wx:elif="{{events.length === 0}}">
      <view class="empty-wrap">
        <text class="empty-icon">🙈</text>
        <text class="empty-title">暂无隐藏的生日</text>
        <text class="empty-sub">在添加/编辑页面关闭「展示到列表」即可隐藏</text>
      </view>
    </block>

    <block wx:else>
      <view class="tip-bar">
        <text class="tip-icon">💡</text>
        <text>以下生日已隐藏，不在首页显示，通知不受影响。</text>
      </view>

      <view class="list">
        <view
          class="item"
          wx:for="{{events}}"
          wx:key="id"
        >
          <!-- 头像 -->
          <view class="item-avatar" style="background:{{item.bg}}" bindtap="goEdit" data-id="{{item.id}}">
            <image wx:if="{{item.avatarUrl}}" class="item-avatar-img" src="{{item.avatarUrl}}" mode="aspectFill" />
            <text wx:else class="item-avatar-letter" style="color:{{item.color}}">{{item.name[0]}}</text>
          </view>

          <!-- 文字信息 -->
          <view class="item-body" bindtap="goEdit" data-id="{{item.id}}">
            <text class="item-name">{{item.name}}</text>
            <text class="item-sub">{{item.sub}}</text>
          </view>

          <!-- 取消隐藏按钮 -->
          <view
            class="unhide-btn {{unhiding[item.id] ? 'unhide-btn-loading' : ''}}"
            bindtap="unhide"
            data-id="{{item.id}}"
          >
            <text wx:if="{{unhiding[item.id]}}" class="unhide-btn-text">处理中</text>
            <text wx:else class="unhide-btn-text">移出隐藏</text>
          </view>

          <!-- 编辑箭头 -->
          <view class="item-edit" bindtap="goEdit" data-id="{{item.id}}">
            <text class="item-arrow">›</text>
          </view>
        </view>
      </view>
    </block>

    <view style="height:60rpx" />
  </scroll-view>
</view>
