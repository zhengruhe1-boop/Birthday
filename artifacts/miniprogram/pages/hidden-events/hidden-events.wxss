.page {
  min-height: 100vh;
  background: #f8fafc;
}

.scroll { height: 100vh; }

.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 48rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #64748b;
  display: block;
  margin-bottom: 12rpx;
}

.empty-sub {
  font-size: 24rpx;
  color: #94a3b8;
  display: block;
  text-align: center;
  line-height: 1.6;
}

.tip-bar {
  margin: 24rpx 24rpx 16rpx;
  background: #fef3c7;
  border-radius: 16rpx;
  padding: 18rpx 24rpx;
  font-size: 22rpx;
  color: #b45309;
  line-height: 1.6;
}

.list {
  margin: 0 24rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #f1f5f9;
}
.item:last-child { border-bottom: none; }
.item:active { background: #f8fafc; }

.item-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f43f5e, #fb923c);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
}

.item-avatar-img {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: block;
}

.item-avatar-letter {
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
}

.item-body {
  flex: 1;
  min-width: 0;
}

.item-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-sub {
  display: block;
  font-size: 22rpx;
  color: #94a3b8;
  margin-top: 4rpx;
}

.item-badge {
  flex-shrink: 0;
  background: #f1f5f9;
  border-radius: 10rpx;
  padding: 4rpx 14rpx;
}
.item-badge text {
  font-size: 20rpx;
  color: #64748b;
}

.item-arrow {
  color: #cbd5e1;
  font-size: 40rpx;
  flex-shrink: 0;
}
