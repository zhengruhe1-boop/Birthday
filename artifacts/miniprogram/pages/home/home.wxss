.home-page {
  min-height: 100vh;
  background: #f8fafc;
}

/* Header */
.home-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx 24rpx;
  padding-top: calc(24rpx + env(safe-area-inset-top));
  background: linear-gradient(135deg, #fff5f7 0%, #fff9f0 100%);
  border-bottom: 1rpx solid rgba(244,63,94,0.08);
}

.header-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  min-width: 0;
}
.header-left:active { opacity: 0.8; }

/* 头部头像容器 */
.avatar-wrap-hd {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  flex-shrink: 0;
  box-shadow: 0 0 0 4rpx rgba(244,63,94,0.18);
  overflow: hidden;
}

.avatar-img-hd {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: block;
}

.avatar-fallback-hd {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f43f5e, #fb923c);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-fallback-hd text {
  color: #fff;
  font-size: 34rpx;
  font-weight: 700;
}

.avatar-logo-emoji {
  font-size: 40rpx;
  line-height: 1;
}

.header-text { flex: 1; min-width: 0; }

.welcome-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #1e293b;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.welcome-sub {
  font-size: 22rpx;
  color: #f43f5e;
  display: block;
  margin-top: 6rpx;
  opacity: 0.7;
}

.icon-btn {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
  flex-shrink: 0;
}
.icon-btn:active { background: #fce7eb; }

/* Search */
.search-wrap {
  padding: 20rpx 32rpx;
  background: #fff;
  border-bottom: 1rpx solid rgba(0,0,0,0.05);
}

.search-bar {
  display: flex;
  align-items: center;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
  border-radius: 20rpx;
  padding: 0 24rpx;
  height: 76rpx;
  gap: 12rpx;
}

.search-icon { font-size: 28rpx; color: #94a3b8; }

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #1e293b;
  background: transparent;
}

.search-clear {
  color: #94a3b8;
  font-size: 28rpx;
  padding: 8rpx;
}

/* Scroll */
.home-scroll {
  height: calc(100vh - 200rpx);
}

/* Content section */
.content-section {
  padding: 28rpx 32rpx 0;
}

/* Contact card */
.contact-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: #fff;
  border-radius: 24rpx;
  border: 1rpx solid rgba(0,0,0,0.06);
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.contact-card:active { opacity: 0.8; }

.contact-avatar-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f43f5e, #fb923c);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
}

.avatar-img { width: 80rpx; height: 80rpx; border-radius: 50%; display: block; }

.avatar-letter {
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
}

.contact-info { flex: 1; min-width: 0; }

.contact-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.contact-sub {
  font-size: 22rpx;
  color: #94a3b8;
  display: block;
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.days-badge {
  flex-shrink: 0;
  padding: 6rpx 16rpx;
  border-radius: 100rpx;
  font-size: 22rpx;
  font-weight: 600;
}
.days-badge.imminent { background: #fff1f2; color: #f43f5e; }
.days-badge.soon { background: #fff7ed; color: #f97316; }
.days-badge.monthly { background: #f1f5f9; color: #64748b; }

.arrow { color: #cbd5e1; font-size: 36rpx; }

/* Event card */
.event-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: #fff;
  border-radius: 24rpx;
  border: 1rpx solid rgba(0,0,0,0.06);
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.event-card:active { opacity: 0.8; }

.event-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}
.event-icon-wrap.rose { background: #fff1f2; }
.event-icon-wrap.orange { background: #fff7ed; }
.event-icon-wrap.violet { background: #f5f3ff; }

.event-info { flex: 1; min-width: 0; }

.event-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.event-sub {
  font-size: 22rpx;
  color: #94a3b8;
  display: block;
  margin-top: 4rpx;
}

.event-meta { flex-shrink: 0; text-align: right; }

.event-days {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
}
.event-days.rose { color: #f43f5e; }
.event-days.orange { color: #f97316; }
.event-days.muted { color: #94a3b8; }

.event-year { font-size: 20rpx; color: #94a3b8; display: block; }

.event-badge {
  flex-shrink: 0;
  padding: 4rpx 14rpx;
  border-radius: 100rpx;
  font-size: 20rpx;
  font-weight: 500;
}

/* Search sub-title */
.search-sub-title {
  font-size: 24rpx;
  color: #94a3b8;
  font-weight: 500;
  padding: 0 4rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.search-sub-title::before {
  content: '';
  display: block;
  width: 4rpx;
  height: 24rpx;
  background: currentColor;
  border-radius: 2rpx;
  opacity: 0.4;
}

.empty-tip {
  text-align: center;
  color: #94a3b8;
  font-size: 26rpx;
  padding: 80rpx 0;
}

/* Empty state */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 48rpx;
  text-align: center;
}

.empty-icon-wrap {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #fff1f2;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.empty-title { font-size: 32rpx; font-weight: 700; color: #1e293b; margin-bottom: 12rpx; display: block; }
.empty-desc { font-size: 26rpx; color: #94a3b8; display: block; }

/* FAB */
.fab-mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.3);
  z-index: 40;
}

.fab-container {
  position: fixed;
  right: 48rpx;
  bottom: calc(40rpx + env(safe-area-inset-bottom));
  z-index: 50;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 16rpx;
}

.fab-menu {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.fab-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  justify-content: flex-end;
}
.fab-item:active { opacity: 0.8; }

.fab-item-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.12);
}
.rose-bg { background: #fff1f2; }
.orange-bg { background: #fff7ed; }
.violet-bg { background: #f5f3ff; }

.fab-item-label {
  font-size: 24rpx;
  font-weight: 500;
  background: rgba(255,255,255,0.95);
  padding: 8rpx 20rpx;
  border-radius: 100rpx;
  color: #1e293b;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.1);
}

.fab-btn {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f43f5e, #fb7185);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(244,63,94,0.35);
  transition: transform 0.2s;
}
.fab-btn.fab-open { background: #64748b; }
.fab-btn:active { transform: scale(0.92); }

.fab-icon {
  color: #fff;
  font-size: 52rpx;
  font-weight: 300;
  line-height: 1;
}

/* Settings */
.settings-sheet { max-height: 60vh; }

.settings-section-title {
  font-size: 22rpx;
  color: #94a3b8;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 1rpx;
  margin-bottom: 12rpx;
  display: block;
}

/* Modal (reused from global) */
.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.4);
  z-index: 100;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.modal-sheet {
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  display: flex;
  flex-direction: column;
  padding-bottom: env(safe-area-inset-bottom);
}

.modal-handle {
  width: 80rpx;
  height: 8rpx;
  background: #e2e8f0;
  border-radius: 4rpx;
  margin: 16rpx auto 0;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 40rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.modal-title { font-size: 32rpx; font-weight: 600; }

.modal-close {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #f1f5f9;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #64748b;
}

.section-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.section-bar {
  width: 6rpx;
  height: 32rpx;
  border-radius: 3rpx;
}

.section-title { font-size: 26rpx; font-weight: 700; }

.section-count {
  font-size: 22rpx;
  padding: 2rpx 14rpx;
  border-radius: 100rpx;
}

.loading-wrap {
  text-align: center;
  color: #94a3b8;
  font-size: 26rpx;
  padding: 80rpx 0;
}

.toggle-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.toggle-info { flex: 1; margin-right: 24rpx; }
.toggle-label { font-size: 28rpx; font-weight: 500; display: block; }
.toggle-desc { font-size: 22rpx; color: #94a3b8; display: block; margin-top: 4rpx; }

.settings-nav-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-top: 1rpx solid #f1f5f9;
}
.nav-arrow {
  font-size: 44rpx;
  color: #cbd5e1;
  font-weight: 300;
  line-height: 1;
}

/* ── 设置面板新样式 ────────────────────────────────────────────────────────── */
.settings-body {
  flex: 1;
  max-height: 72vh;
}

/* 设置面板内边距 */
.settings-inner {
  padding: 0 36rpx;
}

/* 头像区域 */
.profile-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 0 24rpx;
  border-bottom: 1rpx solid #f1f5f9;
  margin-bottom: 24rpx;
}

.profile-avatar-display {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.12);
}

.profile-avatar-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  display: block;
}

/* 头像操作按钮行 */
.avatar-action-row {
  display: flex;
  gap: 20rpx;
}

.avatar-action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 160rpx;
  height: 96rpx;
  border-radius: 20rpx;
  border: none;
  font-size: 22rpx;
  gap: 6rpx;
  padding: 0;
}
.avatar-action-btn::after { border: none; }
.avatar-action-btn:active { opacity: 0.75; }

.wx-avatar-btn {
  background: #07c160;
  color: #fff;
}

.custom-avatar-btn {
  background: #f43f5e;
  color: #fff;
}

.action-btn-icon { font-size: 34rpx; line-height: 1; }
.action-btn-text { font-size: 22rpx; font-weight: 600; }

/* 设置分组 */
.settings-item-group {
  margin-bottom: 32rpx;
}

.settings-group-label {
  font-size: 22rpx;
  color: #94a3b8;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 1rpx;
  display: block;
  margin-bottom: 12rpx;
}

/* 昵称行 */
.nickname-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.nickname-input {
  flex: 1;
  height: 80rpx;
  border: 1rpx solid #e2e8f0;
  border-radius: 16rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #1e293b;
  background: #fafafa;
}

.save-nick-btn {
  flex-shrink: 0;
  height: 80rpx;
  padding: 0 28rpx;
  border-radius: 16rpx;
  background: #f43f5e;
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}
.save-nick-btn.saving { background: #94a3b8; }
.save-nick-btn::after { border: none; }
.save-nick-btn:active { opacity: 0.8; }

.settings-hint {
  font-size: 20rpx;
  color: #94a3b8;
  display: block;
  margin-top: 8rpx;
}

/* 退出按钮 */
.logout-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 20rpx;
  background: #fff0f0;
  color: #ef4444;
  font-size: 28rpx;
  font-weight: 600;
  border: 1rpx solid #fca5a5;
  display: flex;
  align-items: center;
  justify-content: center;
}
.logout-btn::after { border: none; }
.logout-btn:active { opacity: 0.75; }
