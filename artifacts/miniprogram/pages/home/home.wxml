<view class="home-page">

  <!-- 顶部 Header -->
  <view class="home-header">
    <view class="header-left" bindtap="{{loggedIn ? 'openSettings' : 'goLogin'}}">
      <!-- 头像（点击进入设置）：有真实头像 URL 显示头像，否则显示 logo -->
      <view class="avatar-wrap-hd">
        <image wx:if="{{displayAvatarUrl}}"
          class="avatar-img-hd"
          src="{{displayAvatarUrl}}"
          mode="aspectFill"
          binderror="onAvatarImgError" />
        <image wx:else
          class="avatar-img-hd"
          src="/images/logo.jpg"
          mode="aspectFill" />
      </view>
      <view class="header-text">
        <text class="welcome-text">{{displayNickname}}</text>
        <text class="welcome-sub">记住每一个重要的日子</text>
      </view>
    </view>
    <!-- 已登录：设置按钮；未登录：登录按钮 -->
    <view wx:if="{{loggedIn}}" class="icon-btn" bindtap="openSettings">
      <text>⚙️</text>
    </view>
    <view wx:else class="login-btn-hd" bindtap="goLogin">
      <text class="login-btn-hd-text">登录</text>
    </view>
  </view>

  <!-- 未登录引导横幅 -->
  <view wx:if="{{!loggedIn}}" class="guest-banner" bindtap="goLogin">
    <text class="guest-banner-icon">🔑</text>
    <view class="guest-banner-text">
      <text class="guest-banner-title">登录后查看和管理您的生日提醒</text>
      <text class="guest-banner-sub">点击此处快速登录 →</text>
    </view>
  </view>

  <!-- 搜索框 -->
  <view class="search-wrap">
    <view class="search-bar">
      <text class="search-icon">🔍</text>
      <input class="search-input" placeholder="搜索亲友生日,纪念日,事件..."
        value="{{search}}" bindinput="onSearchInput" confirm-type="search" />
      <view wx:if="{{search}}" class="search-clear" bindtap="onSearchClear">
        <text>✕</text>
      </view>
    </view>
  </view>

  <scroll-view class="home-scroll" scroll-y enhanced>

    <!-- ── 搜索结果 ── -->
    <block wx:if="{{search}}">
      <view class="content-section">
        <view class="section-header">
          <view class="section-bar" style="background:#f43f5e" />
          <text class="section-title" style="color:#f43f5e">搜索结果</text>
          <view class="section-count" style="background:#fff1f2;color:#f43f5e">
            {{searchContacts.length + searchEvents.length}} 条
          </view>
        </view>

        <block wx:if="{{!searching && searchContacts.length === 0 && searchEvents.length === 0}}">
          <view class="empty-tip">没有找到相关记录</view>
        </block>

        <block wx:if="{{searchContacts.length > 0}}">
          <view class="search-sub-title">生日联系人</view>
          <view wx:for="{{searchContacts}}" wx:key="id" class="contact-card"
            data-id="{{item.id}}" bindtap="goContact">
            <view class="contact-avatar-wrap">
              <image wx:if="{{item.avatarUrl}}" class="avatar-img" src="{{item.avatarUrl}}" mode="aspectFill" />
              <text wx:else class="avatar-letter">{{item.name[0]}}</text>
            </view>
            <view class="contact-info">
              <view class="contact-name-row">
                <text class="contact-name">{{item.name}}</text>
                <text wx:if="{{item.zodiac}}" class="zodiac-tag">{{item.zodiac}}{{item.shengxiao ? ' · ' + item.shengxiao : ''}}</text>
              </view>
              <text class="contact-sub">{{item.gender ? (item.gender === 'male' ? '男' : '女') + ' · ' : ''}}{{item.birthdayLunar ? '农历' : '公历'}} {{item.birthdayMonth}}月{{item.birthdayDay}}日{{item.relation ? ' · ' + item.relation : ''}}{{item.age ? ' · 距' + item.age + '岁' : ''}}</text>
            </view>
            <text class="arrow">›</text>
          </view>
        </block>

        <block wx:if="{{searchEvents.length > 0}}">
          <view class="search-sub-title" style="margin-top:20rpx">纪念日 / 倒数日 / 其它</view>
          <view wx:for="{{searchEvents}}" wx:key="id" class="event-card"
            data-id="{{item.id}}" bindtap="goEvent">
            <view class="event-icon-wrap {{item.type === 'anniversary' ? 'rose' : item.type === 'countdown' ? 'orange' : 'violet'}}">
              <text>{{item.type === 'anniversary' ? '❤️' : item.type === 'countdown' ? '⏱️' : '✨'}}</text>
            </view>
            <view class="event-info">
              <text class="event-name">{{item.name}}</text>
              <text class="event-sub">{{item.person ? item.person + ' · ' : ''}}{{item.eventDate || item.reminderTime}}</text>
            </view>
            <view class="event-badge {{item.type === 'anniversary' ? 'badge-rose' : item.type === 'countdown' ? 'badge-orange' : 'badge-violet'}}">
              <text>{{item.type === 'anniversary' ? '纪念日' : item.type === 'countdown' ? '倒数日' : '其它'}}</text>
            </view>
          </view>
        </block>
      </view>
    </block>

    <!-- ── 常规内容 ── -->
    <block wx:else>

      <!-- 即将过生日（7天内） -->
      <block wx:if="{{upcoming.imminent.length > 0}}">
        <view class="content-section">
          <view class="section-header">
            <view class="section-bar" style="background:#f43f5e" />
            <text class="section-title" style="color:#f43f5e">即将过生日</text>
            <view class="section-count" style="background:#fff1f2;color:#f43f5e">{{upcoming.imminent.length}}</view>
          </view>
          <view wx:for="{{upcoming.imminent}}" wx:key="id" class="contact-card"
            data-id="{{item.id}}" bindtap="goContact">
            <view class="contact-avatar-wrap">
              <image wx:if="{{item.avatarUrl}}" class="avatar-img" src="{{item.avatarUrl}}" mode="aspectFill" />
              <text wx:else class="avatar-letter">{{item.name[0]}}</text>
            </view>
            <view class="contact-info">
              <view class="contact-name-row">
                <text class="contact-name">{{item.name}}</text>
                <text wx:if="{{item.zodiac}}" class="zodiac-tag">{{item.zodiac}}{{item.shengxiao ? ' · ' + item.shengxiao : ''}}</text>
              </view>
              <text class="contact-sub">{{item.gender ? (item.gender === 'male' ? '男' : '女') + ' · ' : ''}}{{item.birthdayLunar ? '农历' : '公历'}} {{item.birthdayMonth}}月{{item.birthdayDay}}日{{item.relation ? ' · ' + item.relation : ''}}{{item.age ? ' · 距' + item.age + '岁' : ''}}</text>
            </view>
            <view class="days-badge imminent">
              <text>{{item.daysUntilBirthday === 0 ? '今天🎂' : item.daysUntilBirthday === 1 ? '明天' : item.daysUntilBirthday + '天后'}}</text>
            </view>
          </view>
        </view>
      </block>

      <!-- 近期过生日（8-30天） -->
      <block wx:if="{{upcoming.soon.length > 0}}">
        <view class="content-section">
          <view class="section-header">
            <view class="section-bar" style="background:#f97316" />
            <text class="section-title" style="color:#f97316">近期过生日</text>
            <view class="section-count" style="background:#fff7ed;color:#f97316">{{upcoming.soon.length}}</view>
          </view>
          <view wx:for="{{upcoming.soon}}" wx:key="id" class="contact-card"
            data-id="{{item.id}}" bindtap="goContact">
            <view class="contact-avatar-wrap">
              <image wx:if="{{item.avatarUrl}}" class="avatar-img" src="{{item.avatarUrl}}" mode="aspectFill" />
              <text wx:else class="avatar-letter">{{item.name[0]}}</text>
            </view>
            <view class="contact-info">
              <view class="contact-name-row">
                <text class="contact-name">{{item.name}}</text>
                <text wx:if="{{item.zodiac}}" class="zodiac-tag">{{item.zodiac}}{{item.shengxiao ? ' · ' + item.shengxiao : ''}}</text>
              </view>
              <text class="contact-sub">{{item.gender ? (item.gender === 'male' ? '男' : '女') + ' · ' : ''}}{{item.birthdayLunar ? '农历' : '公历'}} {{item.birthdayMonth}}月{{item.birthdayDay}}日{{item.relation ? ' · ' + item.relation : ''}}{{item.age ? ' · 距' + item.age + '岁' : ''}}</text>
            </view>
            <view class="days-badge soon">
              <text>{{item.daysUntilBirthday}}天后</text>
            </view>
          </view>
        </view>
      </block>

      <!-- 一个月后生日（31天以上） -->
      <block wx:if="{{upcoming.monthly.length > 0}}">
        <view class="content-section">
          <view class="section-header">
            <view class="section-bar" style="background:#64748b" />
            <text class="section-title" style="color:#64748b">一个月后生日</text>
            <view class="section-count" style="background:#f1f5f9;color:#64748b">{{upcoming.monthly.length}}</view>
          </view>
          <view wx:for="{{upcoming.monthly}}" wx:key="id" class="contact-card"
            data-id="{{item.id}}" bindtap="goContact">
            <view class="contact-avatar-wrap">
              <image wx:if="{{item.avatarUrl}}" class="avatar-img" src="{{item.avatarUrl}}" mode="aspectFill" />
              <text wx:else class="avatar-letter">{{item.name[0]}}</text>
            </view>
            <view class="contact-info">
              <view class="contact-name-row">
                <text class="contact-name">{{item.name}}</text>
                <text wx:if="{{item.zodiac}}" class="zodiac-tag">{{item.zodiac}}{{item.shengxiao ? ' · ' + item.shengxiao : ''}}</text>
              </view>
              <text class="contact-sub">{{item.gender ? (item.gender === 'male' ? '男' : '女') + ' · ' : ''}}{{item.birthdayLunar ? '农历' : '公历'}} {{item.birthdayMonth}}月{{item.birthdayDay}}日{{item.relation ? ' · ' + item.relation : ''}}{{item.age ? ' · 距' + item.age + '岁' : ''}}</text>
            </view>
            <view class="days-badge monthly">
              <text>{{item.daysUntilBirthday}}天后</text>
            </view>
          </view>
        </view>
      </block>

      <!-- 纪念日 -->
      <block wx:if="{{anniversaries.length > 0}}">
        <view class="content-section">
          <view class="section-header">
            <view class="section-bar" style="background:#fb7185" />
            <text class="section-title" style="color:#fb7185">纪念日</text>
          </view>
          <view wx:for="{{anniversaries}}" wx:key="id" class="event-card"
            data-id="{{item.id}}" bindtap="goEvent">
            <view class="event-icon-wrap rose"><text>❤️</text></view>
            <view class="event-info">
              <text class="event-name">{{item.name}}</text>
              <text class="event-sub">{{item.person ? item.person + ' · ' : ''}}{{item.eventDate}}</text>
            </view>
            <view class="event-meta">
              <text wx:if="{{item.daysUntil === 0}}" class="event-days rose">今天 · {{item.anniversaryYear}}周年</text>
              <block wx:else>
                <text class="event-days rose">{{item.daysUntil}}天后</text>
                <text class="event-year">{{item.anniversaryYear}}周年纪念日</text>
              </block>
            </view>
          </view>
        </view>
      </block>

      <!-- 倒数日 -->
      <block wx:if="{{countdowns.length > 0}}">
        <view class="content-section">
          <view class="section-header">
            <view class="section-bar" style="background:#f97316" />
            <text class="section-title" style="color:#f97316">倒数日</text>
          </view>
          <view wx:for="{{countdowns}}" wx:key="id" class="event-card"
            data-id="{{item.id}}" bindtap="goEvent">
            <view class="event-icon-wrap orange"><text>⏱️</text></view>
            <view class="event-info">
              <text class="event-name">{{item.name}}</text>
              <text class="event-sub">目标日期：{{item.eventDate}}</text>
            </view>
            <view class="event-meta">
              <text wx:if="{{item.daysUntil === 0}}" class="event-days orange">今天</text>
              <text wx:elif="{{item.daysUntil > 0}}" class="event-days orange">还有 {{item.daysUntil}} 天</text>
              <text wx:else class="event-days muted">已过期</text>
            </view>
          </view>
        </view>
      </block>

      <!-- 其它提醒 -->
      <block wx:if="{{others.length > 0}}">
        <view class="content-section">
          <view class="section-header">
            <view class="section-bar" style="background:#8b5cf6" />
            <text class="section-title" style="color:#8b5cf6">其它提醒</text>
          </view>
          <view wx:for="{{others}}" wx:key="id" class="event-card"
            data-id="{{item.id}}" bindtap="goEvent">
            <view class="event-icon-wrap violet"><text>✨</text></view>
            <view class="event-info">
              <text class="event-name">{{item.name}}</text>
              <text class="event-sub">{{item.reminderTime}}</text>
            </view>
          </view>
        </view>
      </block>

      <!-- 空状态 -->
      <block wx:if="{{!loadingUpcoming && !loadingEvents &&
        !upcoming.imminent.length && !upcoming.soon.length && !upcoming.monthly.length &&
        anniversaries.length === 0 && countdowns.length === 0 && others.length === 0}}">
        <view class="empty-state">
          <view class="empty-icon-wrap"><text style="font-size:64rpx">🎂</text></view>
          <text class="empty-title">还没有添加任何记录</text>
          <text class="empty-desc">点击右下角 ＋ 按钮，开始记录重要的日子</text>
        </view>
      </block>

      <!-- 加载中 -->
      <block wx:if="{{loadingUpcoming || loadingEvents}}">
        <view class="loading-wrap"><text>加载中...</text></view>
      </block>

    </block>

    <view style="height:160rpx" />
  </scroll-view>

  <!-- FAB 遮罩 -->
  <view wx:if="{{showFab}}" class="fab-mask" bindtap="closeFab" />

  <!-- FAB -->
  <view class="fab-container">
    <block wx:if="{{showFab}}">
      <view class="fab-menu">
        <view class="fab-item" bindtap="goAddContact">
          <view class="fab-item-icon rose-bg"><text>🎂</text></view>
          <text class="fab-item-label">添加生日</text>
        </view>
        <view class="fab-item" bindtap="goAddAnniversary">
          <view class="fab-item-icon rose-bg"><text>❤️</text></view>
          <text class="fab-item-label">添加纪念日</text>
        </view>
        <view class="fab-item" bindtap="goAddCountdown">
          <view class="fab-item-icon orange-bg"><text>⏱️</text></view>
          <text class="fab-item-label">添加倒数日</text>
        </view>
        <view class="fab-item" bindtap="goAddOther">
          <view class="fab-item-icon violet-bg"><text>✨</text></view>
          <text class="fab-item-label">添加其它提醒</text>
        </view>
      </view>
    </block>
    <view class="fab-btn {{showFab ? 'fab-open' : ''}}" bindtap="toggleFab">
      <text class="fab-icon">{{showFab ? '✕' : '+'}}</text>
    </view>
  </view>

  <!-- 设置面板 -->
  <view wx:if="{{showSettings}}" class="modal-mask" bindtap="closeSettings">
    <view class="modal-sheet" catchtap="noop">
      <view class="modal-handle" />
      <view class="modal-header">
        <text class="modal-title">设置</text>
        <view class="modal-close" bindtap="closeSettings"><text>✕</text></view>
      </view>
      <scroll-view class="settings-body" scroll-y>
        <view class="settings-inner">

          <!-- 头像 + 昵称展示 + 微信获取按钮 -->
          <view class="profile-section">
            <view class="avatar-tap-wrap">
              <image class="profile-avatar-img"
                src="{{displayAvatarUrl || '/images/logo.jpg'}}"
                mode="aspectFill"
                binderror="onAvatarImgError" />
              <view wx:if="{{avatarUploading}}" class="avatar-uploading-mask">
                <text class="avatar-uploading-text">上传中…</text>
              </view>
            </view>
            <view class="nickname-info-row">
              <text class="nickname-info-label">昵称</text>
              <text class="nickname-info-value">{{editNickname || '未设置'}}</text>
            </view>
            <button class="wx-profile-btn" bindtap="openWxProfileModal">获取您微信头像/昵称</button>
          </view>

          <!-- 提醒偏好 -->
          <view class="settings-item-group" style="margin-top:40rpx">
            <text class="settings-group-label">提醒偏好</text>
            <view class="toggle-row">
              <view class="toggle-info">
                <text class="toggle-label">邮件提醒</text>
                <text class="toggle-desc">提前1天和当天发邮件提醒</text>
              </view>
              <switch checked="{{emailNotify}}" bindchange="toggleEmailNotify" color="#f97316" />
            </view>
          </view>

          <view style="height:32rpx" />
          <button class="logout-btn" bindtap="handleLogout">退出登录</button>
          <view style="height:48rpx" />

        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 微信资料授权弹窗 -->
  <view wx:if="{{showWxProfileModal}}" class="modal-mask" bindtap="skipWxProfile">
    <view class="wx-auth-sheet" catchtap="noop">
      <view class="modal-handle" />
      <text class="wx-auth-title">获取你的昵称、头像</text>
      <text class="wx-auth-sub">用于在生日通中标识你的身份</text>

      <!-- ① 头像：点击后微信弹出原生头像选择器 -->
      <view class="wx-auth-step-row">
        <text class="wx-auth-step-label">① 点击头像选择</text>
      </view>
      <button class="wx-auth-avatar-btn"
        open-type="chooseAvatar"
        bindchooseavatar="onWxProfileAvatarChosen">
        <image wx:if="{{wxProfileTemp.avatarUrl}}"
          class="wx-auth-avatar-img"
          src="{{wxProfileTemp.avatarUrl}}"
          mode="aspectFill" />
        <view wx:else class="wx-auth-avatar-placeholder">
          <text class="wx-auth-avatar-icon">👤</text>
          <text class="wx-auth-avatar-hint">点击获取微信头像</text>
        </view>
      </button>

      <!-- ② 昵称：聚焦后微信弹出真实昵称建议键盘 -->
      <view class="wx-auth-step-row">
        <text class="wx-auth-step-label">② 点击昵称输入框</text>
      </view>
      <input class="wx-auth-nickname-input"
        type="nickname"
        name="nickname"
        placeholder="点击获取微信昵称"
        placeholder-class="wx-auth-nickname-ph"
        value="{{wxProfileTemp.nickname}}"
        bindinput="onWxProfileNicknameInput"
        maxlength="20" />

      <!-- 允许按钮 -->
      <button class="wx-auth-confirm-btn" bindtap="saveWxProfile">
        {{avatarUploading ? '保存中…' : '允许'}}
      </button>
      <button class="wx-auth-skip-btn" bindtap="skipWxProfile">取消</button>
    </view>
  </view>

</view>
