<view class="page" wx:if="{{!loading && event}}">

  <!-- ── Hero Banner ─────────────────────────────── -->
  <view class="hero" style="background:{{meta.color}}">
    <!-- Decorative circles -->
    <view class="deco deco1" />
    <view class="deco deco2" />
    <view class="deco deco3" />

    <!-- Type badge -->
    <view class="hero-badge">
      <text class="hero-badge-text">{{meta.icon}} {{meta.label}}</text>
    </view>

    <!-- Event name -->
    <text class="hero-title">{{event.name}}</text>
    <text wx:if="{{event.person}}" class="hero-person">👥 {{event.person}}</text>

    <!-- Days countdown bubble -->
    <view class="hero-days-wrap" wx:if="{{daysText}}">
      <text class="hero-days-text">{{daysText}}</text>
    </view>
  </view>

  <!-- ── Key Stat Card ─────────────────────────────── -->
  <!-- Anniversary: 周年 + 日期 -->
  <view class="stat-card" wx:if="{{event.type === 'anniversary'}}">
    <view class="stat-item">
      <view class="stat-circle" style="background:{{meta.bg}}">
        <text class="stat-num" style="color:{{meta.color}}">{{event.anniversaryYear}}</text>
        <text class="stat-unit" style="color:{{meta.color}}">周年</text>
      </view>
      <text class="stat-label">今年纪念日</text>
    </view>
    <view class="stat-divider" />
    <view class="stat-item">
      <view class="stat-date-wrap">
        <text class="stat-date-main">{{event.eventDate}}</text>
      </view>
      <text class="stat-label">纪念日期</text>
    </view>
  </view>

  <!-- Countdown: 天数 + 日期 -->
  <view class="stat-card" wx:if="{{event.type === 'countdown'}}">
    <view class="stat-item">
      <view class="stat-circle" style="background:{{meta.bg}}">
        <text class="stat-num" style="color:{{meta.color}}">{{event.daysUntil > 0 ? event.daysUntil : 0}}</text>
        <text class="stat-unit" style="color:{{meta.color}}">天</text>
      </view>
      <text class="stat-label">{{event.daysUntil >= 0 ? '剩余天数' : '已过期'}}</text>
    </view>
    <view class="stat-divider" />
    <view class="stat-item">
      <view class="stat-date-wrap">
        <text class="stat-date-main">{{event.eventDate}}</text>
      </view>
      <text class="stat-label">目标日期</text>
    </view>
  </view>

  <!-- Other: 提醒日期 -->
  <view class="stat-card" wx:if="{{event.type === 'other'}}">
    <view class="stat-item-full">
      <text class="stat-remind-icon">⏰</text>
      <text class="stat-remind-date">{{dateValue}}</text>
      <text class="stat-label">提醒时间</text>
    </view>
  </view>

  <!-- ── Info Rows ─────────────────────────────────── -->
  <view class="info-card">
    <text class="info-card-title">提醒设置</text>

    <!-- Reminder timing chips -->
    <view class="info-row" wx:if="{{event.reminderDaysBefore && event.reminderDaysBefore.length}}">
      <view class="info-icon-wrap" style="background:{{meta.bg}}">
        <text style="color:{{meta.color}}">🔔</text>
      </view>
      <view class="info-content">
        <text class="info-label">提醒时机</text>
        <view class="chips-wrap">
          <view wx:for="{{event.reminderDaysBefore}}" wx:key="*this"
            class="chip" style="background:{{meta.bg}};color:{{meta.color}}">
            <text wx:if="{{item === 0}}">当天</text>
            <text wx:else>提前 {{item}} 天</text>
          </view>
        </view>
      </view>
    </view>

    <!-- Send hour -->
    <view class="info-row" wx:if="{{event.reminderSendHour !== undefined && event.reminderSendHour !== null}}">
      <view class="info-icon-wrap" style="background:{{meta.bg}}">
        <text style="color:{{meta.color}}">⏱️</text>
      </view>
      <view class="info-content">
        <text class="info-label">发送时间</text>
        <text class="info-value">每天 {{event.reminderSendHour < 10 ? '0' : ''}}{{event.reminderSendHour}}:00</text>
      </view>
    </view>

    <!-- Email -->
    <view class="info-row" wx:if="{{event.reminderEmail}}">
      <view class="info-icon-wrap" style="background:{{meta.bg}}">
        <text style="color:{{meta.color}}">📧</text>
      </view>
      <view class="info-content">
        <text class="info-label">邮件提醒</text>
        <text class="info-value">{{event.reminderEmail}}</text>
      </view>
    </view>

    <!-- Empty hint -->
    <view wx:if="{{!event.reminderDaysBefore || !event.reminderDaysBefore.length}}" class="empty-hint">
      <text class="empty-hint-text">暂未设置提醒</text>
    </view>

  </view>

  <!-- Edit / Delete -->
  <view class="footer">
    <button class="btn-del" bindtap="handleDelete" loading="{{deleting}}" disabled="{{deleting}}">
      删除
    </button>
    <button class="edit-btn" style="background:{{meta.color}}" bindtap="goEdit" disabled="{{deleting}}">
      ✏️  编辑事件
    </button>
  </view>

</view>

<!-- Loading -->
<view wx:if="{{loading}}" class="loading-wrap">
  <view class="loading-spinner" />
  <text class="loading-text">加载中...</text>
</view>

<!-- Error -->
<view wx:if="{{!loading && !event}}" class="loading-wrap">
  <text class="loading-text">加载失败，请返回重试</text>
</view>
