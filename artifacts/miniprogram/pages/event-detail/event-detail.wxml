<view class="page" wx:if="{{!loading && event}}">

  <!-- Hero Card -->
  <view class="hero-card" style="background:{{meta.bg}}">
    <view class="hero-icon-wrap" style="background:#fff">
      <text class="hero-icon">{{meta.icon}}</text>
    </view>
    <view class="hero-body">
      <view class="type-badge" style="background:{{meta.tagBg}};color:{{meta.tagColor}}">{{meta.label}}</view>
      <text class="hero-name">{{event.name}}</text>
      <text wx:if="{{daysText}}" class="hero-days" style="color:{{meta.color}}">{{daysText}}</text>
    </view>
  </view>

  <!-- Info List -->
  <view class="info-card">

    <!-- Date -->
    <view class="info-row" wx:if="{{dateValue}}">
      <text class="info-label">{{dateLabel}}</text>
      <text class="info-value">{{dateValue}}</text>
    </view>

    <!-- Person (anniversary only) -->
    <view class="info-row" wx:if="{{event.person}}">
      <text class="info-label">相关人物</text>
      <text class="info-value">{{event.person}}</text>
    </view>

    <!-- Anniversary year -->
    <view class="info-row" wx:if="{{event.type === 'anniversary' && event.anniversaryYear !== undefined}}">
      <text class="info-label">今年周年</text>
      <text class="info-value" style="color:{{meta.color}}">第 {{event.anniversaryYear}} 周年</text>
    </view>

    <!-- Reminder email -->
    <view class="info-row" wx:if="{{event.reminderEmail}}">
      <text class="info-label">邮件提醒</text>
      <text class="info-value">{{event.reminderEmail}}</text>
    </view>

    <!-- Reminder days -->
    <view class="info-row" wx:if="{{event.reminderDaysBefore && event.reminderDaysBefore.length}}">
      <text class="info-label">提醒时机</text>
      <view class="chips-wrap">
        <view wx:for="{{event.reminderDaysBefore}}" wx:key="*this"
          class="chip" style="background:{{meta.tagBg}};color:{{meta.tagColor}}">
          <text wx:if="{{item === 0}}">当天</text>
          <text wx:else>提前{{item}}天</text>
        </view>
      </view>
    </view>

    <!-- Send hour -->
    <view class="info-row" wx:if="{{event.reminderSendHour !== undefined && event.reminderSendHour !== null}}">
      <text class="info-label">发送时间</text>
      <text class="info-value">每天 {{event.reminderSendHour < 10 ? '0' : ''}}{{event.reminderSendHour}}:00</text>
    </view>

  </view>

  <!-- Edit Button -->
  <view class="footer">
    <button class="edit-btn" style="background:{{meta.color}}" bindtap="goEdit">
      编辑
    </button>
  </view>

</view>

<!-- Loading -->
<view wx:if="{{loading}}" class="loading-wrap">
  <text class="loading-text">加载中...</text>
</view>

<!-- Error / empty -->
<view wx:if="{{!loading && !event}}" class="loading-wrap">
  <text class="loading-text">加载失败，请返回重试</text>
</view>
