/* ── Page ──────────────────────────────────────────────────── */
.page {
  min-height: 100vh;
  background: #F4ECE8;
  padding-bottom: 200rpx;
}

/* ── Hero Banner ───────────────────────────────────────────── */
.hero {
  position: relative;
  overflow: hidden;
  padding: 72rpx 40rpx 64rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 18rpx;
}

/* Decorative background circles */
.deco {
  position: absolute;
  border-radius: 50%;
  background: rgba(255,255,255,0.12);
  pointer-events: none;
}
.deco1 { width: 320rpx; height: 320rpx; top: -120rpx; right: -80rpx; }
.deco2 { width: 200rpx; height: 200rpx; bottom: -60rpx; left: -40rpx; background: rgba(255,255,255,0.08); }
.deco3 { width: 120rpx; height: 120rpx; top: 40rpx; left: 60rpx; background: rgba(255,255,255,0.10); }

.hero-badge {
  background: rgba(255,255,255,0.25);
  border-radius: 32rpx;
  padding: 8rpx 28rpx;
  backdrop-filter: blur(8px);
}
.hero-badge-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #fff;
  letter-spacing: 1rpx;
}

.hero-title {
  font-size: 52rpx;
  font-weight: 800;
  color: #fff;
  line-height: 1.25;
  letter-spacing: 1rpx;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.15);
  max-width: 560rpx;
}

.hero-person {
  font-size: 28rpx;
  color: rgba(255,255,255,0.85);
  font-weight: 500;
}

.hero-days-wrap {
  margin-top: 8rpx;
  background: rgba(255,255,255,0.22);
  border-radius: 40rpx;
  padding: 12rpx 36rpx;
  border: 1rpx solid rgba(255,255,255,0.35);
}
.hero-days-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
}

/* ── Stat Card ─────────────────────────────────────────────── */
.stat-card {
  margin: -32rpx 28rpx 20rpx;
  background: #fff;
  border-radius: 28rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.10);
  display: flex;
  align-items: center;
  padding: 40rpx 32rpx;
  position: relative;
  z-index: 10;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
}

.stat-item-full {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.stat-divider {
  width: 1rpx;
  height: 80rpx;
  background: #f1f5f9;
  margin: 0 16rpx;
}

.stat-circle {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.stat-num {
  font-size: 44rpx;
  font-weight: 800;
  line-height: 1;
}
.stat-unit {
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1.4;
}

.stat-date-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.stat-date-main {
  font-size: 32rpx;
  font-weight: 700;
  color: #1e293b;
  letter-spacing: 1rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #94a3b8;
  font-weight: 500;
}

/* Other type – full width remind card */
.stat-remind-icon {
  font-size: 56rpx;
  line-height: 1;
}
.stat-remind-date {
  font-size: 36rpx;
  font-weight: 700;
  color: #1e293b;
  letter-spacing: 1rpx;
  margin-top: 4rpx;
}

/* ── Info Card ─────────────────────────────────────────────── */
.info-card {
  margin: 0 28rpx 20rpx;
  background: #fff;
  border-radius: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
  overflow: hidden;
}

.info-card-title {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  color: #94a3b8;
  letter-spacing: 2rpx;
  text-transform: uppercase;
  padding: 28rpx 32rpx 4rpx;
}

.info-row {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f8fafc;
}
.info-row:last-child {
  border-bottom: none;
}

.info-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 30rpx;
}

.info-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding-top: 4rpx;
}

.info-label {
  font-size: 24rpx;
  color: #94a3b8;
  font-weight: 500;
}

.info-value {
  font-size: 30rpx;
  color: #1e293b;
  font-weight: 600;
}

.chips-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.chip {
  font-size: 26rpx;
  font-weight: 600;
  padding: 8rpx 22rpx;
  border-radius: 24rpx;
}

/* Empty hint */
.empty-hint {
  padding: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.empty-hint-text {
  font-size: 26rpx;
  color: #cbd5e1;
}

/* ── Footer ────────────────────────────────────────────────── */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(244,236,232,0.95);
  backdrop-filter: blur(12px);
  border-top: 1rpx solid rgba(0,0,0,0.06);
}

.edit-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  letter-spacing: 2rpx;
  box-shadow: 0 6rpx 24rpx rgba(0,0,0,0.18);
}
.edit-btn::after { border: none; }

/* ── Loading ───────────────────────────────────────────────── */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  min-height: 60vh;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f1f5f9;
  border-top-color: #f43f5e;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #94a3b8;
}
