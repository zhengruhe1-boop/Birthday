.page {
  min-height: 100vh;
  background: #F4ECE8;
  padding: 24rpx 24rpx 200rpx;
  box-sizing: border-box;
}

/* ── Hero Card ─────────────────────────────────────────────── */
.hero-card {
  display: flex;
  align-items: flex-start;
  gap: 28rpx;
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  margin-bottom: 20rpx;
}

.hero-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
}

.hero-icon {
  font-size: 48rpx;
  line-height: 1;
}

.hero-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.type-badge {
  align-self: flex-start;
  font-size: 22rpx;
  font-weight: 600;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.hero-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #1e293b;
  line-height: 1.3;
}

.hero-days {
  font-size: 28rpx;
  font-weight: 600;
}

/* ── Info Card ─────────────────────────────────────────────── */
.info-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 8rpx 0;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #94a3b8;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.info-value {
  font-size: 28rpx;
  color: #1e293b;
  font-weight: 500;
  text-align: right;
  flex: 1;
}

.chips-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  justify-content: flex-end;
  flex: 1;
}

.chip {
  font-size: 24rpx;
  font-weight: 600;
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
}

/* ── Footer ────────────────────────────────────────────────── */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #F4ECE8;
  border-top: 1rpx solid rgba(0,0,0,0.06);
}

.edit-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.15);
}

.edit-btn::after {
  border: none;
}

/* ── Loading ───────────────────────────────────────────────── */
.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
}

.loading-text {
  font-size: 28rpx;
  color: #94a3b8;
}
