.page-wrap {
  padding: 24rpx 28rpx;
  background: #f5f5f5;
  min-height: 100vh;
  box-sizing: border-box;
}

/* ── 搜索栏 ── */
.search-wrap {
  margin-bottom: 32rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  height: 80rpx;
  background: #fff8f0;
  border: 2rpx solid #f5d6a8;
  border-radius: 40rpx;
  padding: 0 24rpx 0 28rpx;
  box-sizing: border-box;
  transition: border-color 0.2s, background 0.2s;
}

.search-bar-active {
  border-color: #e67e22;
  background: #ffffff;
}

.search-icon {
  margin-right: 16rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
}

.search-icon-text {
  font-size: 32rpx;
  line-height: 1;
}

.search-input {
  flex: 1;
  min-width: 0;
  height: 76rpx;
  line-height: 76rpx;
  font-size: 28rpx;
  color: #333333;
  background: transparent;
}

.search-input-ph {
  color: #c4a06a;
  font-size: 28rpx;
}

.search-clear {
  flex-shrink: 0;
  width: 48rpx;
  height: 48rpx;
  line-height: 44rpx;
  text-align: center;
  font-size: 36rpx;
  color: #c4a06a;
}

/* ── 停用 ── */
.disabled-banner {
  text-align: center;
  padding: 20rpx;
  margin-bottom: 20rpx;
  background: #fff2f0;
  border-radius: 16rpx;
  color: #dc2626;
  font-size: 26rpx;
}

/* ── 分类区块 ── */
.category-section {
  background: #ffffff;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  padding: 28rpx 20rpx 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.03);
}

.category-header {
  margin-bottom: 24rpx;
  padding-left: 8rpx;
}

.category-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #e67e22;
}

/* ── 4 列网格 ── */
.tool-grid {
  display: flex;
  flex-wrap: wrap;
}

.tool-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 28rpx;
}

.tool-icon-box {
  position: relative;
  width: 96rpx;
  height: 96rpx;
  margin-bottom: 14rpx;
  flex-shrink: 0;
}

.tool-icon-wrap {
  width: 100%;
  height: 100%;
  border-radius: 24rpx;
  background: #f8f9fb;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.tool-icon-img {
  width: 60rpx;
  height: 60rpx;
}

.tool-icon-emoji {
  font-size: 44rpx;
  line-height: 1;
}

.tool-name {
  font-size: 22rpx;
  color: #333333;
  text-align: center;
  max-width: 150rpx;
  line-height: 1.3;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  word-break: break-all;
}

.tool-external-tag {
  position: absolute;
  top: -4rpx;
  right: -8rpx;
  z-index: 2;
  font-size: 16rpx;
  line-height: 1.2;
  color: #ffffff;
  background: #e67e22;
  border-radius: 8rpx;
  padding: 2rpx 8rpx;
  white-space: nowrap;
  box-shadow: 0 2rpx 6rpx rgba(230, 126, 34, 0.35);
}

/* ── 加载 & 空状态 ── */
.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #999999;
}

.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
  text-align: center;
  padding: 0 40rpx;
}

.error-hint {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #f56c6c;
  text-align: center;
  padding: 0 40rpx;
}

.retry-btn {
  margin-top: 24rpx;
  font-size: 26rpx;
  color: #e67e22;
  text-align: center;
}

.bottom-safe {
  height: 40rpx;
}
