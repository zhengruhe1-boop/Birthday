.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  color: #999;
  font-size: 28rpx;
  gap: 12rpx;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 8rpx;
}

.empty-sub {
  font-size: 22rpx;
  color: #bbb;
}

.msg-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.msg-item {
  position: relative;
  padding-right: 56rpx;
}

.msg-item:active {
  opacity: 0.85;
}

.msg-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.status-tag {
  font-size: 20rpx;
  font-weight: 600;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
}

.status-pending { background: #fff5eb; color: #e67e22; }
.status-processing { background: #eff6ff; color: #2563eb; }
.status-resolved { background: #f0fdf4; color: #16a34a; }
.status-announcement { background: #fff5eb; color: #d35400; }

.unread-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #e67e22;
  flex-shrink: 0;
}

.msg-time {
  margin-left: auto;
  font-size: 22rpx;
  color: #999;
}

.msg-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
  line-height: 1.4;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.msg-content {
  display: block;
  font-size: 28rpx;
  color: #334155;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.msg-reply-preview {
  margin-top: 16rpx;
  padding: 16rpx;
  background: #fff5eb;
  border-radius: 12rpx;
  overflow: hidden;
  max-width: 100%;
  box-sizing: border-box;
}

.reply-label {
  display: block;
  font-size: 22rpx;
  color: #e67e22;
  font-weight: 600;
}

.reply-text {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100%;
}

.msg-arrow {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  color: #ccc;
  font-size: 40rpx;
}
