.legal-page {
  min-height: 100vh;
  background: #ffffff;
}

.legal-scroll {
  height: 100vh;
}

.legal-body {
  padding: 32rpx 36rpx 40rpx;
  display: flex;
  flex-direction: column;
}

.legal-content {
  font-size: 26rpx;
  color: #475569;
  line-height: 1.9;
  display: block;
  white-space: pre-wrap;
}

.legal-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100vh;
}

.loading-text {
  font-size: 28rpx;
  color: #94a3b8;
}

.legal-error {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  gap: 20rpx;
}

.error-icon {
  font-size: 60rpx;
}

.error-text {
  font-size: 28rpx;
  color: #64748b;
}

.retry-btn {
  margin-top: 16rpx;
  padding: 16rpx 48rpx;
  background: #e67e22;
  border-radius: 48rpx;
}

.retry-btn text {
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
}
