<view class="legal-page">

  <view wx:if="{{loading}}" class="legal-loading">
    <text class="loading-text">加载中…</text>
  </view>

  <view wx:elif="{{error}}" class="legal-error">
    <text class="error-icon">⚠️</text>
    <text class="error-text">加载失败，请检查网络</text>
    <view class="retry-btn" bindtap="retry"><text>重新加载</text></view>
  </view>

  <scroll-view wx:else class="legal-scroll" scroll-y>
    <view class="legal-body">
      <text class="legal-content" user-select>{{content}}</text>
    </view>
    <view style="height:60rpx" />
  </scroll-view>

</view>
