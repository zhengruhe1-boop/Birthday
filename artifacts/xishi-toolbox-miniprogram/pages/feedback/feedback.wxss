.feedback-page {
  padding-bottom: 40rpx;
}

.form-card {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #172033;
  margin-bottom: 16rpx;
}

.required {
  color: #e67e22;
}

.form-textarea {
  width: 100%;
  min-height: 280rpx;
  font-size: 28rpx;
  color: #334155;
  line-height: 1.6;
  background: #f8f8f8;
  border-radius: 18rpx;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background: #f8f8f8;
  border-radius: 18rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.char-count {
  display: block;
  text-align: right;
  font-size: 22rpx;
  color: #999;
  margin-top: 12rpx;
}

.submit-btn {
  margin-top: 16rpx;
  padding: 24rpx 0;
  font-size: 30rpx;
}

.form-tip {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: #999;
  margin-top: 24rpx;
}

.form-label-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.form-label-sub {
  font-size: 22rpx;
  color: #999;
}

.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item,
.image-add {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  position: relative;
  overflow: hidden;
}

.image-preview {
  width: 100%;
  height: 100%;
  display: block;
}

.image-remove {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.55);
  color: #fff;
  font-size: 28rpx;
  line-height: 40rpx;
  text-align: center;
}

.image-add {
  border: 2rpx dashed #f5d6a8;
  background: #fff8f0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.image-add-icon {
  font-size: 48rpx;
  color: #e67e22;
  line-height: 1;
}

.image-add-text {
  font-size: 22rpx;
  color: #e67e22;
}
