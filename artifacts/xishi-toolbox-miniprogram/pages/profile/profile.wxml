<view class="page">
  <view class="card user-card" bindtap="onUserCardTap">
    <view wx:if="{{loggedIn}}" class="avatar">{{avatarText}}</view>
    <image wx:else class="avatar avatar--logo" src="/images/logo.png" mode="aspectFit" />
    <view class="name">{{displayName}}</view>
    <view class="muted">{{loggedIn ? '' : '点击登录，可使用问题反馈等功能'}}</view>
    <button wx:if="{{loggedIn}}" class="ghost-btn action" catchtap="logout">退出登录</button>
    <button wx:else class="primary-btn action" catchtap="goLogin">立即登录</button>
  </view>

  <view class="card menu-card">
    <view class="menu-item" bindtap="goFeedback">
      <view class="menu-icon">✍️</view>
      <text class="menu-name">问题反馈</text>
      <text wx:if="{{!loggedIn}}" class="login-hint">需登录</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goMessages">
      <view class="menu-icon">📬</view>
      <text class="menu-name">消息中心</text>
      <text wx:if="{{loggedIn && unreadCount > 0}}" class="unread-badge">{{unreadCount > 99 ? '99+' : unreadCount}}</text>
      <text wx:elif="{{!loggedIn}}" class="login-hint">需登录</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goLegal" data-type="terms">
      <view class="menu-icon">📄</view>
      <text class="menu-name">用户协议</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goLegal" data-type="privacy">
      <view class="menu-icon">🔒</view>
      <text class="menu-name">隐私政策</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>
</view>
