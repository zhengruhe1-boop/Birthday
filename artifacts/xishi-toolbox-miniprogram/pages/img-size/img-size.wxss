.page {
  min-height: 100vh;
  background: #f8fafc;
  padding: 24rpx 24rpx 0;
  box-sizing: border-box;
}

.page-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1e293b;
  display: block;
  margin-bottom: 4rpx;
}

.page-sub {
  font-size: 22rpx;
  color: #94a3b8;
  display: block;
  margin-bottom: 24rpx;
}

/* ── 离屏 Canvas ── */
.offscreen-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 10px;
  height: 10px;
}

/* ── 选图区 ── */
.select-zone {
  background: #fff;
  border: 2rpx dashed #fdba74;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  gap: 12rpx;
}

.select-icon { font-size: 72rpx; line-height: 1; }
.select-text { font-size: 30rpx; font-weight: 600; color: #e67e22; }
.select-hint { font-size: 22rpx; color: #94a3b8; }

/* ── 卡片 ── */
.section-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
  margin-bottom: 16rpx;
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.card-title { font-size: 26rpx; font-weight: 600; color: #334155; }

.size-badge {
  font-size: 22rpx;
  color: #64748b;
  background: #f1f5f9;
  padding: 4rpx 16rpx;
  border-radius: 100rpx;
  font-weight: 500;
}

.size-badge--green { background: #dcfce7; color: #16a34a; }

.preview-img { width: 100%; border-radius: 12rpx; display: block; }

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12rpx;
  padding: 8rpx 0;
}

.info-label { font-size: 22rpx; color: #94a3b8; }
.info-val { font-size: 22rpx; color: #334155; font-weight: 500; }

.reselect-row { display: flex; justify-content: flex-end; margin-top: 8rpx; }

.reselect-btn {
  font-size: 22rpx;
  color: #e67e22;
  padding: 6rpx 16rpx;
  border-radius: 100rpx;
  border: 1rpx solid #fed7aa;
}

/* ── 尺寸输入 ── */
.dim-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.dim-field {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.dim-label {
  font-size: 22rpx;
  color: #64748b;
  font-weight: 500;
}

.dim-input {
  height: 80rpx;
  line-height: 80rpx;
  border: 2rpx solid #e2e8f0;
  border-radius: 16rpx;
  padding: 0 20rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #1e293b;
  text-align: center;
  background: #f8fafc;
}

.lock-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #f1f5f9;
  margin-top: 28rpx;
  flex-shrink: 0;
  font-size: 32rpx;
}

.lock-btn--active {
  background: #fff7ed;
  box-shadow: 0 0 0 2rpx #e67e22;
}

.lock-hint {
  text-align: center;
  font-size: 20rpx;
  color: #94a3b8;
  margin-top: 12rpx;
  margin-bottom: 16rpx;
}

/* ── 预设尺寸 ── */
.preset-title {
  font-size: 22rpx;
  font-weight: 600;
  color: #64748b;
  margin-bottom: 12rpx;
}

.preset-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.preset-btn {
  padding: 10rpx 20rpx;
  font-size: 22rpx;
  font-weight: 500;
  color: #64748b;
  background: #f1f5f9;
  border-radius: 12rpx;
  text-align: center;
}

.preset-btn:active {
  background: #fff7ed;
  color: #e67e22;
}

/* ── 格式选择 ── */
.format-group {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.format-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  background: #f1f5f9;
  border-radius: 16rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #64748b;
  border: 2rpx solid transparent;
}

.format-item--active {
  background: #fff7ed;
  color: #e67e22;
  border-color: #fdba74;
}

/* ── 操作按钮 ── */
.process-btn {
  width: 100%;
  background: linear-gradient(135deg, #e67e22 0%, #f59e0b 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  border-radius: 20rpx;
  height: 96rpx;
  line-height: 96rpx;
  padding: 0;
  border: none;
  box-shadow: 0 6rpx 24rpx rgba(230,126,34,0.35);
  letter-spacing: 1rpx;
  margin-bottom: 20rpx;
}

.process-btn::after { border: none; }
.process-btn:active { opacity: 0.88; }
.process-btn--loading { opacity: 0.7; }

/* ── 结果 ── */
.result-card { border: 2rpx solid #dcfce7; }

.compare-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #f8fafc;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin: 14rpx 0;
}

.compare-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.compare-label { font-size: 20rpx; color: #94a3b8; }
.compare-val { font-size: 24rpx; font-weight: 700; color: #334155; }
.compare-val--green { color: #16a34a; }
.compare-sub { font-size: 20rpx; color: #94a3b8; }
.compare-arrow { font-size: 28rpx; color: #cbd5e1; }

.save-btn {
  width: 100%;
  background: #16a34a;
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  border-radius: 16rpx;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0;
  border: none;
  box-shadow: 0 4rpx 20rpx rgba(22,163,74,0.3);
}

.save-btn::after { border: none; }
.save-btn:active { opacity: 0.85; }
.save-btn--loading { opacity: 0.7; }

/* ── 重置 ── */
.reset-row {
  text-align: center;
  padding: 16rpx 0;
}

.reset-text {
  font-size: 24rpx;
  color: #94a3b8;
}
