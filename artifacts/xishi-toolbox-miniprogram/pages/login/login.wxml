<view class="login-page">
  <image class="logo-img" src="/images/logo.png" mode="aspectFit" />
  <view class="title">登录惜时工具箱</view>

  <button class="login-btn" loading="{{loading}}" bindtap="login">
    <text class="login-btn-text">微信登录</text>
  </button>

  <view class="agree" bindtap="toggleAgree">
    <view class="checkbox {{agreed ? 'checked' : ''}}">{{agreed ? '✓' : ''}}</view>
    <view class="agree-text">
      我已阅读并同意
      <text class="link" catchtap="openTerms">《用户协议》</text>
      和
      <text class="link" catchtap="openPrivacy">《隐私政策》</text>
    </view>
  </view>

  <view wx:if="{{error}}" class="error">{{error}}</view>
</view>
