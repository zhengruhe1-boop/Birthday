<view class="page">
  <view class="header">
    <view class="title">全部工具</view>
    <view class="desc">工具列表由后台统一配置，按分类分组展示。</view>
  </view>

  <view wx:if="{{loading}}" class="loading">
    <view class="loading-text">加载中…</view>
  </view>

  <view wx:elif="{{toolGroups.length === 0}}" class="empty">
    <view class="empty-icon">🔧</view>
    <view class="empty-text">暂无可用工具</view>
  </view>

  <block wx:else>
    <block wx:for="{{toolGroups}}" wx:for-item="group" wx:key="id">
      <view class="group-label"><text wx:if="{{group.icon}}">{{group.icon}} </text>{{group.name}}</view>
      <view class="list">
        <view
          wx:for="{{group.tools}}"
          wx:for-item="tool"
          wx:key="id"
          class="row card"
          bindtap="openTool"
          data-id="{{tool.id}}"
          data-type="{{tool.type}}"
          data-path="{{tool.path}}"
          data-app-id="{{tool.app_id}}"
          data-page-path="{{tool.page_path}}"
        >
          <view class="icon-box">
            <view class="icon">
              <image wx:if="{{tool.iconIsUrl}}" src="{{tool.icon}}" class="icon-img" mode="aspectFill" />
              <text wx:else>{{tool.icon}}</text>
            </view>
            <view class="badge" wx:if="{{tool.type === 'external'}}">外部</view>
          </view>
          <view class="main">
            <view class="name">{{tool.name}}</view>
            <view class="desc">{{tool.desc}}</view>
          </view>
          <view class="arrow" wx:if="{{tool.type !== 'external'}}">›</view>
        </view>
      </view>
    </block>
  </block>
</view>
